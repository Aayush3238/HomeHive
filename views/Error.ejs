<!DOCTYPE html>
<html lang="en">
<head>
<%- include('./partials/head', {
    pageTitle: pageTitle || 'HomeHive | Page Not Found',
    pageDescription: pageDescription || 'The page you requested is unavailable.'
}) %>
</head>
<body>
    <%- include('./partials/nav', { activeNav: 'explore' }) %>

    <section class="auth-shell">
        <div class="page-card auth-card" style="text-align:center;">
            <div style="display:flex;flex-direction:column;align-items:center;gap:0.75rem;">
                <span class="eyebrow"><i class="fa-solid fa-triangle-exclamation"></i> Error</span>
                <h1 style="font-size:clamp(2.4rem,7vw,4.6rem);"><%= pageTitle ? 'Something went wrong' : 'Page not found' %></h1>
                <p><%= pageTitle ? 'An unexpected error occurred. Please try again later.' : 'The page you are looking for does not exist or has been removed.' %></p>
                <% if (typeof error !== 'undefined' && error) { %>
                    <pre style="text-align:left;background:#fdd;padding:1rem;border-radius:0.5rem;max-width:100%;overflow:auto;font-size:0.85rem;"><%= error %></pre>
                <% } %>
                <div style="display:flex;gap:0.65rem;flex-wrap:wrap;justify-content:center;">
                    <a href="/" class="btn btn-accent">
                        <i class="fa-solid fa-compass"></i>
                        <span>Back to home</span>
                    </a>
                    <a href="/login" class="btn btn-secondary">
                        <i class="fa-solid fa-user"></i>
                        <span>Go to login</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <div class="footer-brand">
                    <i class="fa-solid fa-house"></i>
                    <strong>HomeHive</strong>
                </div>
                <p class="footer-desc">A simple platform for finding and listing properties.</p>
            </div>
            <div class="footer-col">
                <h4>Navigation</h4>
                <a href="/">Home</a>
                <% if (!isLoggedIn) { %>
                    <a href="/login">Login</a>
                    <a href="/signup">Sign up</a>
                <% } else { %>
                    <a href="/store/favourite-list">Saved homes</a>
                <% } %>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <a href="mailto:support@homehive.com">support@homehive.com</a>
                <p class="footer-contact-item"><i class="fa-solid fa-location-dot"></i> India</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 HomeHive. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/animations.js"></script>
</body>
</html>
