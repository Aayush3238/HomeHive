<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head', {
        pageTitle: 'HomeHive | Page Not Found',
        pageDescription: 'The page you requested is unavailable.'
    }) %>
</head>
<body>
    <%- include('./partials/nav', { activeNav: 'explore' }) %>

    <section class="hero-section">
        <div class="hero-card reveal" style="text-align:center;">
            <div class="hero-copy" style="justify-items:center;">
                <span class="eyebrow"><i class="fa-solid fa-triangle-exclamation"></i> Error state</span>
                <h1 style="font-size:clamp(2.4rem,7vw,4.6rem);">Lost in the layout?</h1>
                <p>The page you requested does not exist or is no longer available. Use the main listing explorer to get back into the product flow.</p>
                <div class="hero-cta-row" style="justify-content:center;">
                    <a href="/" class="btn btn-accent">
                        <i class="fa-solid fa-compass"></i>
                        <span>Back to home</span>
                    </a>
                    <a href="/login" class="btn btn-secondary">
                        <i class="fa-solid fa-user"></i>
                        <span>Go to login</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/animations.js"></script>
</body>
</html>
