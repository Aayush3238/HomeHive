<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Reserve',
        pageDescription: 'Reserve your selected property on HomeHive.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'explore' }) %>

    <section class="auth-shell">
        <div class="page-card auth-card" style="text-align:center;">
            <div style="display:flex;flex-direction:column;align-items:center;gap:0.75rem;">
                <span class="eyebrow"><i class="fa-solid fa-calendar-check"></i> Reservation</span>
                <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Reserve this property</h1>
                <p>Contact the owner or send an offer to proceed with this listing.</p>
                <div style="display:flex;gap:0.65rem;flex-wrap:wrap;justify-content:center;">
                    <a href="/" class="btn btn-accent">
                        <i class="fa-solid fa-compass"></i>
                        <span>Browse listings</span>
                    </a>
                    <a href="/store/bookings" class="btn btn-secondary">
                        <i class="fa-regular fa-calendar-check"></i>
                        <span>View meetings</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/animations.js"></script>
</body>
</html>
