<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Meetings',
        pageDescription: 'Track scheduled meetings and continue buyer-owner conversations.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'bookings' }) %>

    <section class="page-section reveal">
        <div class="section-heading">
            <span class="eyebrow"><i class="fa-regular fa-calendar-check"></i> Meetings</span>
            <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Scheduled conversations</h1>
        </div>

        <% if (meetings && meetings.length > 0) { %>
            <div class="card-list">
                <% meetings.forEach(meeting => { %>
                    <% const otherParticipant = meeting.participants.find(p => p._id.toString() !== user.id); %>
                    <article class="meeting-card card-item" style="padding:1.35rem; display:grid; gap:1.25rem;">
                        <div class="stack">
                            <div class="price-highlight">
                                <div>
                                    <div class="price-label">Meeting with</div>
                                    <strong style="font-size:1.05rem;"><%= otherParticipant.firstname %> <%= otherParticipant.lastname %></strong>
                                </div>
                                <span class="status <%= meeting.status %>"><%= meeting.status %></span>
                            </div>
                            <div class="home-meta">
                                <span class="meta-pill"><i class="fa-regular fa-calendar"></i><%= new Date(meeting.scheduledDate).toLocaleString() %></span>
                                <span class="meta-pill"><i class="fa-solid fa-location-dot"></i><%= meeting.location %></span>
                            </div>
                            <% if (meeting.notes) { %>
                                <p style="font-size:0.88rem;line-height:1.65;"><%= meeting.notes %></p>
                            <% } %>
                        </div>
                        <div class="card-actions">
                            <button type="button" class="btn btn-accent" onclick="openChat('<%= meeting.buyRequest._id %>', <%- JSON.stringify(`${otherParticipant.firstname} ${otherParticipant.lastname}`) %>)">
                                <i class="fa-solid fa-comments"></i>
                                <span>Open chat</span>
                            </button>
                            <% if (meeting.status === 'scheduled') { %>
                                <form action="/meeting/<%= meeting._id %>/status" method="POST" class="inline-form" onsubmit="return confirm('Mark this meeting as completed?')">
                                    <input type="hidden" name="status" value="completed">
                                    <button type="submit" class="btn btn-accent">
                                        <i class="fa-solid fa-check"></i>
                                        <span>Complete</span>
                                    </button>
                                </form>
                                <form action="/meeting/<%= meeting._id %>/status" method="POST" class="inline-form" onsubmit="return confirm('Cancel this meeting?')">
                                    <input type="hidden" name="status" value="cancelled">
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fa-solid fa-xmark"></i>
                                        <span>Cancel</span>
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state page-card">
                <span class="empty-state-icon"><i class="fa-regular fa-calendar"></i></span>
                <span class="eyebrow">No meetings scheduled</span>
                <h3>No confirmed meetings yet</h3>
                <p>Accepted requests that turn into meetings will appear here automatically.</p>
            </div>
        <% } %>
    </section>

    <div id="chatModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="chatTitle">
        <div class="modal-content chat-modal">
            <button type="button" class="close" onclick="closeChatModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="chat-shell">
                <div class="chat-header">
                    <span class="chat-avatar"><i class="fa-solid fa-user"></i></span>
                    <div>
                        <h3 id="chatTitle">Conversation</h3>
                        <p class="chat-notice">Messages are encrypted for security.</p>
                    </div>
                </div>
                <div id="chatMessages" class="chat-messages"></div>
                <div class="chat-composer">
                    <input type="text" id="messageInput" placeholder="Type your message..." autocomplete="off">
                    <button type="button" onclick="sendMessage()" class="btn btn-accent">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <div class="footer-brand">
                    <i class="fa-solid fa-house"></i>
                    <strong>HomeHive</strong>
                </div>
                <p class="footer-desc">A simple platform for finding and listing properties.</p>
            </div>
            <div class="footer-col">
                <h4>Navigation</h4>
                <a href="/">Explore listings</a>
                <a href="/store/favourite-list">Saved homes</a>
                <a href="/store/my-requests">My requests</a>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <a href="mailto:support@homehive.com">support@homehive.com</a>
                <p class="footer-contact-item"><i class="fa-solid fa-location-dot"></i> India</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 HomeHive. All rights reserved.</p>
        </div>
    </footer>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/crypto.js"></script>
    <script>
        const socket = io();
        const currentUserId = <%- JSON.stringify(user.id) %>;
        const currentUserName = <%- JSON.stringify(`${user.firstname} ${user.lastname}`) %>;
        const chatModal = document.getElementById('chatModal');
        const chatMessages = document.getElementById('chatMessages');
        const chatTitle = document.getElementById('chatTitle');
        let currentRequestId = null;

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        async function renderMessages(messages) {
            chatMessages.innerHTML = '';

            if (!messages.length) {
                chatMessages.innerHTML = '<div class="chat-empty">No messages yet. Start the conversation.</div>';
                return;
            }

            for (const msg of messages) {
                const isMine = msg.sender && msg.sender._id === currentUserId;
                const row = document.createElement('div');
                row.className = `message-row ${isMine ? 'mine' : 'theirs'}`;
                const senderName = isMine ? currentUserName : `${msg.sender.firstname} ${msg.sender.lastname}`;
                const timeLabel = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const displayMessage = msg.message || '';

                row.innerHTML = `
                    ${isMine ? '' : '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>'}
                    <div class="message-card">
                        <div class="message-meta">
                            <span>${escapeHtml(senderName)}</span>
                            <span>&middot;</span>
                            <span>${escapeHtml(timeLabel)}</span>
                        </div>
                        <div class="message-text">${escapeHtml(displayMessage)}</div>
                    </div>
                    ${isMine ? '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>' : ''}
                `;
                chatMessages.appendChild(row);
            }

            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        async function openChat(requestId, otherName) {
            currentRequestId = requestId;
            chatTitle.textContent = `Chat with ${otherName}`;
            chatModal.classList.add('show');
            loadMessages(requestId);
            socket.emit('joinRoom', requestId);
        }

        function closeChatModal() {
            chatModal.classList.remove('show');
            currentRequestId = null;
            chatMessages.innerHTML = '';
        }

        function loadMessages(requestId) {
            chatMessages.innerHTML = '<div class="chat-empty">Loading messages...</div>';
            fetch(`/messages/${requestId}`)
                .then(response => {
                    if (!response.ok) throw new Error('Failed to load messages');
                    return response.json();
                })
                .then(messages => renderMessages(messages))
                .catch(() => {
                    chatMessages.innerHTML = '<div class="chat-empty">Could not load messages. Please try again.</div>';
                });
        }

        async function sendMessage() {
            const messageInput = document.getElementById('messageInput');
            const message = messageInput.value.trim();
            if (!message || !currentRequestId) return;

            socket.emit('sendMessage', {
                requestId: currentRequestId,
                message: message,
                senderId: currentUserId
            });
            messageInput.value = '';
            if (window.showToast) window.showToast('Message sent.', 'success');
        }

        socket.on('newMessage', (data) => {
            if (data.requestId === currentRequestId) loadMessages(currentRequestId);
        });

        document.getElementById('messageInput').addEventListener('keypress', function (event) {
            if (event.key === 'Enter') sendMessage();
        });

        chatModal.addEventListener('click', (event) => {
            if (event.target === chatModal) closeChatModal();
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && chatModal.classList.contains('show')) closeChatModal();
        });
    </script>
    <script src="/js/animations.js"></script>
</body>
</html>
