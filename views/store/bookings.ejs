<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeHive - Meetings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="listing-bg listing-bg-left" aria-hidden="true"></div>
    <div class="listing-bg listing-bg-right" aria-hidden="true"></div>
    <div class="site-nav">
        <div class="navbar">
            <a class="nav-brand" href="/">
                <i class="fa-solid fa-house"></i>
                <span>HomeHive</span>
            </a>
            <div class="nav-links">
                <a href="/"><i class="fa-solid fa-compass"></i> Explore</a>
                <% if (user && user.role === 'Owner') { %>
                    <a href="/host/add-home"><i class="fa-solid fa-square-plus"></i> Add Listing</a>
                    <a href="/host/host-homelist"><i class="fa-solid fa-table-cells-large"></i> Dashboard</a>
                    <a href="/host/buy-requests"><i class="fa-solid fa-comments"></i> Requests</a>
                <% } %>
                <% if (user && user.role === 'Buyer') { %>
                    <a href="/store/favourite-list"><i class="fa-regular fa-heart"></i> Saved</a>
                <% } %>
                <a class="is-active" href="/store/bookings"><i class="fa-regular fa-calendar-check"></i> Meetings</a>
                <a href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
            </div>
        </div>
    </div>

    <section class="page-section">
        <div class="section-heading">
            <span class="eyebrow"><i class="fa-regular fa-calendar-check"></i> Meetings</span>
            <h1>Your scheduled meetings</h1>
            <p>Track every property conversation, meeting location, and next step from one place.</p>
        </div>

        <% if (meetings && meetings.length > 0) { %>
            <div class="card-list">
                <% meetings.forEach(meeting => { %>
                    <% const otherParticipant = meeting.participants.find(p => p._id.toString() !== user.id); %>
                    <article class="meeting-card card-item" style="padding:1.35rem; display:grid; gap:1rem;">
                        <div class="stack" style="gap:0.75rem;">
                            <h3>Meeting with <%= otherParticipant.firstname %> <%= otherParticipant.lastname %></h3>
                            <div class="home-meta">
                                <span class="meta-pill"><i class="fa-regular fa-calendar"></i><%= new Date(meeting.scheduledDate).toLocaleString() %></span>
                                <span class="meta-pill"><i class="fa-solid fa-location-dot"></i><%= meeting.location %></span>
                                <span class="status <%= meeting.status %>"><%= meeting.status %></span>
                            </div>
                            <% if (meeting.notes) { %>
                                <p><strong style="color: var(--color-charcoal-700);">Notes:</strong> <%= meeting.notes %></p>
                            <% } %>
                        </div>
                        <div class="card-actions">
                            <button type="button" class="btn btn-accent" onclick="openChat('<%= meeting.buyRequest._id %>', <%- JSON.stringify(`${otherParticipant.firstname} ${otherParticipant.lastname}`) %>)">
                                <i class="fa-solid fa-comments"></i>
                                <span>Open Chat</span>
                            </button>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="page-card" style="text-align:center;">
                <h2>No meetings scheduled yet</h2>
                <p>Accepted requests that turn into meetings will appear here.</p>
            </div>
        <% } %>
    </section>

    <div id="chatModal" class="modal">
        <div class="modal-content chat-modal">
            <button type="button" class="close" onclick="closeChatModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="chat-shell">
                <div class="chat-header">
                    <span class="chat-avatar"><i class="fa-solid fa-user"></i></span>
                    <div>
                        <h2 id="chatTitle">Conversation</h2>
                        <p>Keep the meeting thread active with fast follow-ups.</p>
                    </div>
                </div>
                <div id="chatMessages" class="chat-messages"></div>
                <div class="chat-composer">
                    <input type="text" id="messageInput" placeholder="Type your message...">
                    <button type="button" onclick="sendMessage()" class="btn btn-accent">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const currentUserId = <%- JSON.stringify(user.id) %>;
        const currentUserName = <%- JSON.stringify(`${user.firstname} ${user.lastname}`) %>;
        const chatModal = document.getElementById('chatModal');
        const chatMessages = document.getElementById('chatMessages');
        const chatTitle = document.getElementById('chatTitle');
        let currentRequestId = null;

        function renderMessages(messages) {
            chatMessages.innerHTML = '';

            if (!messages.length) {
                chatMessages.innerHTML = '<div class="chat-empty"><p>No messages yet. Start the conversation.</p></div>';
                return;
            }

            messages.forEach((msg) => {
                const isMine = msg.sender && msg.sender._id === currentUserId;
                const row = document.createElement('div');
                row.className = `message-row ${isMine ? 'mine' : 'theirs'}`;
                row.innerHTML = `
                    ${isMine ? '' : '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>'}
                    <div class="message-card">
                        <div class="message-meta">
                            <span>${isMine ? currentUserName : `${msg.sender.firstname} ${msg.sender.lastname}`}</span>
                            <span>•</span>
                            <span>${new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                        </div>
                        <div class="message-text">${msg.message}</div>
                    </div>
                    ${isMine ? '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>' : ''}
                `;
                chatMessages.appendChild(row);
            });

            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function openChat(requestId, otherName) {
            currentRequestId = requestId;
            chatTitle.textContent = `Chat with ${otherName}`;
            chatModal.classList.add('show');
            loadMessages(requestId);
            socket.emit('joinRoom', requestId);
        }

        function closeChatModal() {
            chatModal.classList.remove('show');
            currentRequestId = null;
            chatMessages.innerHTML = '';
        }

        function loadMessages(requestId) {
            fetch(`/messages/${requestId}`)
                .then(response => response.json())
                .then(messages => renderMessages(messages));
        }

        function sendMessage() {
            const messageInput = document.getElementById('messageInput');
            const message = messageInput.value.trim();
            if (message && currentRequestId) {
                socket.emit('sendMessage', {
                    requestId: currentRequestId,
                    message,
                    senderId: currentUserId
                });
                messageInput.value = '';
                messageInput.focus();
            }
        }

        socket.on('newMessage', (data) => {
            if (data.requestId === currentRequestId) {
                loadMessages(currentRequestId);
            }
        });

        document.getElementById('messageInput').addEventListener('keypress', function (event) {
            if (event.key === 'Enter') {
                sendMessage();
            }
        });

        chatModal.addEventListener('click', (event) => {
            if (event.target === chatModal) {
                closeChatModal();
            }
        });
    </script>
    <script src="/js/animations.js"></script>
</body>
</html>
