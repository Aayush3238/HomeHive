<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Find your next home',
        pageDescription: 'Browse verified properties across India. Filter by budget, type, or location. Save favourites and connect directly with owners.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'explore' }) %>

    <section class="hero-section">
        <div class="hero-card reveal">
            <div class="hero-layout">
                <div class="hero-copy">
                    <h1>Find your next home, simply.</h1>
                    <p class="hero-lead">Browse verified properties across cities. Filter by budget, type, or location. Save what you like and connect directly with owners.</p>

                    <div class="hero-search-shell">
                        <div class="hero-search">
                            <input id="propertySearch" type="text" placeholder="Search by city, state, or address">
                            <button type="button" class="btn btn-accent" id="searchActionBtn">
                                <i class="fa-solid fa-sliders"></i>
                                <span>Search</span>
                            </button>
                        </div>
                        <div class="hero-filters">
                            <label class="filter-chip">
                                <span>Budget</span>
                                <select id="budgetPreference">
                                    <option value="any">Any budget</option>
                                    <option value="2500000">Up to Rs 25L</option>
                                    <option value="5000000">Up to Rs 50L</option>
                                    <option value="10000000">Up to Rs 1Cr</option>
                                    <option value="20000000">Up to Rs 2Cr</option>
                                </select>
                            </label>
                            <label class="filter-chip">
                                <span>Property type</span>
                                <select id="typePreference">
                                    <option value="any">Any type</option>
                                    <option value="apartment">Apartment</option>
                                    <option value="villa">Villa</option>
                                    <option value="house">House</option>
                                    <option value="studio">Studio</option>
                                    <option value="plot">Plot</option>
                                </select>
                            </label>
                        </div>
                    </div>

                    <div class="hero-stats">
                        <div class="hero-stat">
                            <strong><%= SubmittedDetails.length %></strong>
                            <span>Listings</span>
                        </div>
                        <div class="hero-stat">
                            <strong><%= [...new Set(SubmittedDetails.map(home => home.address?.city).filter(Boolean))].length %></strong>
                            <span>Cities</span>
                        </div>
                    </div>

                    <div class="hero-cta-row">
                        <a class="btn btn-accent" href="#listing-explorer">
                            <i class="fa-solid fa-compass"></i>
                            <span>Browse listings</span>
                        </a>
                        <% if (!isLoggedIn) { %>
                            <a class="btn btn-secondary" href="/signup">
                                <i class="fa-solid fa-user-plus"></i>
                                <span>Create account</span>
                            </a>
                        <% } else if (user && user.role === 'Owner') { %>
                            <a class="btn btn-secondary" href="/host/add-home">
                                <i class="fa-solid fa-square-plus"></i>
                                <span>Add your property</span>
                            </a>
                        <% } else { %>
                            <a class="btn btn-secondary" href="/store/favourite-list">
                                <i class="fa-regular fa-heart"></i>
                                <span>Saved homes</span>
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="page-section reveal" id="listing-explorer">
        <div class="listings-toolbar">
            <div class="section-heading" style="margin-bottom:0;">
                <span class="eyebrow"><i class="fa-solid fa-building"></i> Listings</span>
                <h2>Available properties</h2>
            </div>
            <div class="toolbar-actions">
                <label class="field">
                    <span>Sort by</span>
                    <select id="sortPreference">
                        <option value="smart">Best match</option>
                        <option value="price-asc">Price: low to high</option>
                        <option value="price-desc">Price: high to low</option>
                        <option value="city">City</option>
                    </select>
                </label>
                <label class="field">
                    <span>Per page</span>
                    <select id="pageSizePreference">
                        <option value="6">6</option>
                        <option value="9" selected>9</option>
                        <option value="12">12</option>
                    </select>
                </label>
            </div>
        </div>

        <p id="searchSummary" class="helper-text" style="margin:0 0 1rem;"></p>

        <ul class="homes-list" id="listingGrid">
            <% SubmittedDetails.forEach(home => { %>
                <% const imageUrl = getHomeImageUrl(home.homeImage, { width: 720, height: 450 }); %>
                <% const imageSrcSet = getHomeImageSrcSet(home.homeImage, [320, 480, 720, 960], { height: 450 }); %>
                <li
                    class="home-card listing-card"
                    data-search="<%= `${home.address?.formattedAddress || ''} ${home.description || ''}`.toLowerCase() %>"
                    data-price="<%= Number(home.price) || 0 %>"
                    data-type="<%= (home.propertyType || '').toLowerCase() %>"
                    data-city="<%= (home.address?.city || '').toLowerCase() %>"
                >
                    <div class="home-media">
                        <img
                            src="<%= imageUrl %>"
                            <% if (imageSrcSet) { %>srcset="<%= imageSrcSet %>"<% } %>
                            sizes="(max-width: 840px) 100vw, (max-width: 1100px) 50vw, 33vw"
                            alt="Photo of <%= home.address?.formattedAddress || 'property' %>"
                            class="home-img"
                            loading="lazy"
                            decoding="async"
                            onerror="this.onerror=null;this.src='<%= imageFallbackUrl %>';"
                        />
                        <div class="card-badges">
                            <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
                                <span class="verified-badge"><i class="fa-solid fa-circle-check"></i> Verified</span>
                                <span class="match-badge" data-match-score>60% match</span>
                            </div>
                            <% if (isLoggedIn) { %>
                                <form action="/favourites/<%= home.id %>" method="POST" class="inline-form" data-toast-submit="Saved to your shortlist." data-toast-type="success">
                                    <button type="submit" class="save-button btn-secondary" aria-label="Save this property">
                                        <i class="fa-regular fa-heart"></i>
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                    <div class="home-card-body">
                        <div class="price-highlight">
                            <div>
                                <div class="price-label">Starting price</div>
                                <strong>Rs <%= home.price %></strong>
                            </div>
                            <% if (home.propertyType) { %>
                                <span class="meta-pill"><i class="fa-solid fa-house"></i><%= home.propertyType.charAt(0).toUpperCase() + home.propertyType.slice(1) %></span>
                            <% } %>
                        </div>
                        <h3><%= home.address?.formattedAddress || 'Property listing' %></h3>
                        <div class="home-meta">
                            <span class="meta-pill"><i class="fa-solid fa-location-dot"></i><%= home.address?.city || home.address?.state || 'Location pending' %></span>
                            <span class="meta-pill"><i class="fa-solid fa-bolt"></i>Fast response</span>
                        </div>
                        <p class="home-description"><%= home.description %></p>
                    </div>
                    <div class="card-actions">
                        <% if (isLoggedIn && user.role === 'Buyer') { %>
                            <button type="button" class="btn-accent" onclick="openBuyRequestModal('<%= home.id %>', '<%= home.price %>')">
                                <i class="fa-solid fa-paper-plane"></i>
                                <span>Send request</span>
                            </button>
                        <% } %>
                        <a class="Details" href="/home/<%= home.id %>">
                            <i class="fa-solid fa-arrow-up-right-from-square"></i>
                            <span>View details</span>
                        </a>
                    </div>
                </li>
            <% }) %>
        </ul>

        <div class="pagination" id="pagination"></div>

        <div class="empty-state page-card" id="listingEmptyState" hidden>
            <span class="empty-state-icon"><i class="fa-solid fa-house"></i></span>
            <span class="eyebrow">No matching homes</span>
            <h3>Try adjusting your filters</h3>
            <p>No properties match the current criteria. Try a different city, budget, or property type.</p>
        </div>
    </section>

    <section class="page-section reveal" id="why-homehive">
        <div class="section-heading">
            <span class="eyebrow"><i class="fa-solid fa-house"></i> Why HomeHive</span>
            <h2>Built for buyers and owners</h2>
        </div>
        <div class="feature-grid">
            <article class="info-card">
                <i class="fa-solid fa-magnifying-glass"></i>
                <h3>Easy property discovery</h3>
                <p>Search, filter, and sort listings by location, budget, or type. Smart matching helps you find what fits without endless scrolling.</p>
            </article>
            <article class="info-card">
                <i class="fa-solid fa-circle-check"></i>
                <h3>Verified listings</h3>
                <p>Every property goes through verification. What you see is what is available — no stale or misleading posts.</p>
            </article>
            <article class="info-card">
                <i class="fa-solid fa-comments"></i>
                <h3>Direct communication</h3>
                <p>Send an offer or message the owner directly. No middlemen, no delays. Discuss pricing, schedule visits, and close faster.</p>
            </article>
            <article class="info-card">
                <i class="fa-solid fa-gauge"></i>
                <h3>Simple experience</h3>
                <p>A clean interface for buyers and a straightforward dashboard for owners. No clutter, no confusion.</p>
            </article>
        </div>
    </section>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <div class="footer-brand">
                    <i class="fa-solid fa-house"></i>
                    <strong>HomeHive</strong>
                </div>
                <p class="footer-desc">A simple platform for finding and listing properties. No middlemen, no clutter.</p>
            </div>
            <div class="footer-col">
                <h4>Navigation</h4>
                <a href="/">Explore listings</a>
                <a href="#why-homehive">Why HomeHive</a>
                <% if (!isLoggedIn) { %>
                    <a href="/login">Login</a>
                    <a href="/signup">Sign up</a>
                <% } else if (user && user.role === 'Owner') { %>
                    <a href="/host/host-homelist">Dashboard</a>
                    <a href="/host/add-home">Add listing</a>
                <% } else { %>
                    <a href="/store/favourite-list">Saved homes</a>
                    <a href="/store/bookings">Meetings</a>
                <% } %>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <a href="mailto:support@homehive.com">support@homehive.com</a>
                <p class="footer-contact-item"><i class="fa-solid fa-location-dot"></i> India</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 HomeHive. All rights reserved.</p>
        </div>
    </footer>

    <div id="buyRequestModal" class="modal">
        <div class="modal-content">
            <button type="button" class="close" onclick="closeBuyRequestModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="section-heading" style="margin-bottom:1rem;">
                <span class="eyebrow"><i class="fa-solid fa-paper-plane"></i> Offer</span>
                <h3>Send an offer</h3>
                <p>Submit your proposed price and a message to the owner.</p>
            </div>
            <form id="buyRequestForm" action="/buy-request" method="POST">
                <input type="hidden" id="homeId" name="homeId">
                <div class="field">
                    <label for="offeredPrice">Your offered price</label>
                    <input type="number" id="offeredPrice" name="offeredPrice" required>
                </div>
                <div class="field">
                    <label for="message">Message to owner</label>
                    <textarea id="message" name="message" rows="4" placeholder="Explain your interest, timeline, or financing status..." required></textarea>
                </div>
                <button type="submit" class="btn-accent">
                    <i class="fa-solid fa-paper-plane"></i>
                    <span>Send request</span>
                </button>
            </form>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('propertySearch');
        const searchActionBtn = document.getElementById('searchActionBtn');
        const budgetPreference = document.getElementById('budgetPreference');
        const typePreference = document.getElementById('typePreference');
        const sortPreference = document.getElementById('sortPreference');
        const pageSizePreference = document.getElementById('pageSizePreference');
        const listingGrid = document.getElementById('listingGrid');
        const listingCards = Array.from(document.querySelectorAll('.listing-card'));
        const searchSummary = document.getElementById('searchSummary');
        const emptyState = document.getElementById('listingEmptyState');
        const pagination = document.getElementById('pagination');
        const buyRequestModal = document.getElementById('buyRequestModal');
        const smartMatchStorageKey = 'homehive.smartMatchPreferences.v2';
        let currentPage = 1;

        const inferPropertyType = (text) => {
            const value = text.toLowerCase();
            if (value.includes('villa')) return 'villa';
            if (value.includes('apartment') || value.includes('flat')) return 'apartment';
            if (value.includes('studio')) return 'studio';
            if (value.includes('plot') || value.includes('land')) return 'plot';
            return 'house';
        };

        function savePreferences() {
            localStorage.setItem(smartMatchStorageKey, JSON.stringify({
                search: searchInput.value,
                budget: budgetPreference.value,
                type: typePreference.value,
                sort: sortPreference.value,
                pageSize: pageSizePreference.value,
            }));
        }

        function loadPreferences() {
            try {
                const saved = JSON.parse(localStorage.getItem(smartMatchStorageKey) || '{}');
                if (typeof saved.search === 'string') searchInput.value = saved.search;
                if (typeof saved.budget === 'string') budgetPreference.value = saved.budget;
                if (typeof saved.type === 'string') typePreference.value = saved.type;
                if (typeof saved.sort === 'string') sortPreference.value = saved.sort;
                if (typeof saved.pageSize === 'string') pageSizePreference.value = saved.pageSize;
            } catch (error) {
                localStorage.removeItem(smartMatchStorageKey);
            }
        }

        function getSmartMatchScore(card) {
            const query = searchInput.value.trim().toLowerCase();
            const budget = Number(budgetPreference.value || 0);
            const preferredType = typePreference.value;
            const cardText = card.dataset.search;
            const cardPrice = Number(card.dataset.price || 0);
            const cardType = card.dataset.type || inferPropertyType(cardText);
            let score = 52;

            score += query ? (cardText.includes(query) ? 24 : 6) : 10;
            score += budget > 0 ? (cardPrice <= budget ? 18 : cardPrice <= budget * 1.12 ? 10 : 2) : 12;
            score += preferredType !== 'any' ? (cardType === preferredType ? 16 : 2) : 8;
            return Math.max(52, Math.min(98, score));
        }

        function refreshSmartMatchScores() {
            listingCards.forEach((card) => {
                const score = getSmartMatchScore(card);
                const scoreNode = card.querySelector('[data-match-score]');
                if (scoreNode) scoreNode.textContent = `${score}% match`;
                card.dataset.match = String(score);
            });
        }

        function getFilteredCards() {
            const query = searchInput.value.trim().toLowerCase();
            const priceCap = Number(budgetPreference.value || 0);
            const preferredType = typePreference.value;

            return listingCards.filter((card) => {
                const matchesQuery = !query || card.dataset.search.includes(query);
                const matchesBudget = !priceCap || Number(card.dataset.price || 0) <= priceCap * 1.12;
                const cardType = card.dataset.type || inferPropertyType(card.dataset.search);
                const matchesType = preferredType === 'any' || cardType === preferredType;
                return matchesQuery && matchesBudget && matchesType;
            });
        }

        function sortCards(cards) {
            const sortValue = sortPreference.value;
            const sorted = [...cards];

            sorted.sort((a, b) => {
                if (sortValue === 'price-asc') return Number(a.dataset.price) - Number(b.dataset.price);
                if (sortValue === 'price-desc') return Number(b.dataset.price) - Number(a.dataset.price);
                if (sortValue === 'city') return (a.dataset.city || '').localeCompare(b.dataset.city || '');
                return Number(b.dataset.match || 0) - Number(a.dataset.match || 0);
            });

            sorted.forEach((card) => listingGrid.appendChild(card));
            return sorted;
        }

        function renderPagination(totalCount, pageSize) {
            const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
            if (currentPage > totalPages) currentPage = totalPages;
            pagination.innerHTML = '';
            if (totalCount <= pageSize) return totalPages;

            for (let page = 1; page <= totalPages; page += 1) {
                const button = document.createElement('button');
                button.type = 'button';
                button.textContent = page;
                button.className = page === currentPage ? 'is-active' : '';
                button.addEventListener('click', () => {
                    currentPage = page;
                    filterListings();
                });
                pagination.appendChild(button);
            }

            return totalPages;
        }

        function filterListings(resetPage = false) {
            if (resetPage) currentPage = 1;
            refreshSmartMatchScores();
            const pageSize = Number(pageSizePreference.value || 9);
            const filtered = sortCards(getFilteredCards());
            const totalPages = renderPagination(filtered.length, pageSize);
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;

            listingCards.forEach((card) => {
                card.hidden = true;
                card.style.display = 'none';
            });

            filtered.slice(start, end).forEach((card) => {
                card.hidden = false;
                card.style.display = '';
            });

            if (searchSummary) {
                searchSummary.textContent = filtered.length
                    ? `Showing ${Math.min(end, filtered.length)} of ${filtered.length} matching homes across ${totalPages} page${totalPages > 1 ? 's' : ''}.`
                    : 'No listings match the current filters.';
            }

            if (emptyState) emptyState.hidden = filtered.length !== 0;
            savePreferences();
        }

        function openBuyRequestModal(homeId, price) {
            document.getElementById('homeId').value = homeId;
            document.getElementById('offeredPrice').value = price;
            buyRequestModal.classList.add('show');
        }

        function closeBuyRequestModal() {
            buyRequestModal.classList.remove('show');
        }

        loadPreferences();
        searchInput.addEventListener('input', () => filterListings(true));
        budgetPreference.addEventListener('change', () => filterListings(true));
        typePreference.addEventListener('change', () => filterListings(true));
        sortPreference.addEventListener('change', () => filterListings(true));
        pageSizePreference.addEventListener('change', () => filterListings(true));
        searchActionBtn.addEventListener('click', () => filterListings(true));

        buyRequestModal.addEventListener('click', (event) => {
            if (event.target === buyRequestModal) closeBuyRequestModal();
        });

        filterListings(true);
    </script>
    <script src="/js/animations.js"></script>
</body>
</html>
