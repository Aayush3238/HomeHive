<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeHive</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="listing-bg listing-bg-left" aria-hidden="true"></div>
    <div class="listing-bg listing-bg-right" aria-hidden="true"></div>
    <div class="site-nav">
        <div class="navbar">
            <a class="nav-brand" href="/">
                <i class="fa-solid fa-house"></i>
                <span>HomeHive</span>
            </a>
            <div class="nav-links">
                <a class="is-active" href="/"><i class="fa-solid fa-compass"></i> Explore</a>
                <% if (isLoggedIn) { %>
                    <a href="/store/favourite-list"><i class="fa-regular fa-heart"></i> Saved</a>
                    <% if (user.role === 'Owner') { %>
                        <a href="/host/add-home"><i class="fa-solid fa-square-plus"></i> Add Listing</a>
                        <a href="/host/host-homelist"><i class="fa-solid fa-table-cells-large"></i> Dashboard</a>
                        <a href="/host/buy-requests"><i class="fa-solid fa-comments"></i> Requests</a>
                    <% } %>
                    <a href="/store/bookings"><i class="fa-regular fa-calendar-check"></i> Meetings</a>
                    <a href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
                <% } else { %>
                    <a href="/login"><i class="fa-solid fa-user"></i> Login</a>
                    <a href="/signup"><i class="fa-solid fa-user-plus"></i> Sign Up</a>
                <% } %>
            </div>
        </div>
    </div>

    <section class="hero-section">
        <div class="hero-blob hero-blob--1" aria-hidden="true"></div>
        <div class="hero-blob hero-blob--2" aria-hidden="true"></div>
        <div class="hero-blob hero-blob--3" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-card">
            <div class="hero-copy">
                <span class="eyebrow"><i class="fa-solid fa-house-chimney-window"></i> Real estate marketplace</span>
                <h1>Find polished homes without the noisy search experience.</h1>
                <p class="hero-lead">Browse owner-listed properties with cleaner discovery, shortlist tracking, and faster decision-making from one professional workflow.</p>
                <div class="hero-search-shell">
                    <div class="hero-search">
                        <input id="propertySearch" type="text" placeholder="Search by city, state, country, or description">
                        <button type="button" class="btn btn-accent" id="searchActionBtn">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <span>Search</span>
                        </button>
                    </div>
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <strong><%= SubmittedDetails.length %></strong>
                            <span>Active listings</span>
                        </div>
                        <div class="hero-stat">
                            <strong><%= SubmittedDetails.filter(home => home.location && home.location.coordinates && home.location.coordinates.length === 2).length %></strong>
                            <span>Map-ready homes</span>
                        </div>
                    </div>
                    <div class="hero-filters" aria-label="Listing preferences">
                        <label class="filter-chip">
                            <span>Budget</span>
                            <select id="budgetPreference">
                                <option value="any">Any budget</option>
                                <option value="2500000">Up to Rs 25L</option>
                                <option value="5000000">Up to Rs 50L</option>
                                <option value="10000000">Up to Rs 1Cr</option>
                                <option value="20000000">Up to Rs 2Cr</option>
                            </select>
                        </label>
                        <label class="filter-chip">
                            <span>Property type</span>
                            <select id="typePreference">
                                <option value="any">Any type</option>
                                <option value="apartment">Apartment</option>
                                <option value="villa">Villa</option>
                                <option value="house">House</option>
                                <option value="studio">Studio</option>
                                <option value="plot">Plot</option>
                            </select>
                        </label>
                    </div>
                </div>
      0      </div>
        </div>
    </section>

    <div class="listings-toolbar">
        <div class="section-heading" style="margin:0; width:auto;">
            <span class="eyebrow"><i class="fa-solid fa-building"></i> Listings</span>
            <h2>Available homes</h2>
        </div>
        <p id="searchSummary"></p>
    </div>

    <ul class="homes-list" id="listingGrid">
        <% SubmittedDetails.forEach(home => { %>
            <% const imageUrl = getHomeImageUrl(home.homeImage, { width: 720, height: 420 }); %>
            <% const imageSrcSet = getHomeImageSrcSet(home.homeImage, [320, 480, 720, 960], { height: 420 }); %>
            <li
                class="home-card listing-card"
                data-search="<%= `${home.address.formattedAddress} ${home.description}`.toLowerCase() %>"
                data-price="<%= Number(home.price) || 0 %>"
                data-city="<%= (home.address.city || '').toLowerCase() %>"
            >
                <div class="home-media">
                    <img
                        src="<%= imageUrl %>"
                        <% if (imageSrcSet) { %>srcset="<%= imageSrcSet %>"<% } %>
                        sizes="(max-width: 640px) 100vw, (max-width: 1100px) 50vw, 33vw"
                        alt="Photo of <%= home.address.formattedAddress %>"
                        class="home-img"
                        loading="lazy"
                        decoding="async"
                        onerror="this.onerror=null;this.src='<%= imageFallbackUrl %>';"
                    />
                    <div class="card-badges">
                        <span class="match-badge" data-match-score>60% match</span>
                    </div>
                </div>
                <div class="home-card-body">
                    <h3><%= home.address.formattedAddress %></h3>
                    <div class="home-meta">
                        <span class="meta-pill"><i class="fa-solid fa-location-dot"></i><%= home.address.city || home.address.state %></span>
                        <span class="meta-pill"><i class="fa-solid fa-wallet"></i>Rs <%= home.price %></span>
                    </div>
                    <p class="home-description"><%= home.description %></p>
                </div>
                <div class="card-actions">
                    <% if (isLoggedIn && user.role === 'Buyer') { %>
                        <button type="button" onclick="openBuyRequestModal('<%= home.id %>', '<%= home.price %>')">
                            <i class="fa-solid fa-paper-plane"></i>
                            <span>Send Buy Request</span>
                        </button>
                    <% } %>
                    <a class="Details" href="/home/<%= home.id %>">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i>
                        <span>View Details</span>
                    </a>
                    <% if (isLoggedIn) { %>
                        <form action="/favourites/<%= home.id %>" method="POST" class="inline-form">
                            <button type="submit" class="btn-secondary" style="width:100%;display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.75rem 1rem;border-radius:0.85rem;font-weight:700;font-size:0.88rem;cursor:pointer;border:1px solid rgba(28,24,22,0.10);background:rgba(255,252,249,0.95);color:#1c1816;transition:all 0.25s ease;">
                                <i class="fa-regular fa-heart"></i>
                                <span>Save</span>
                            </button>
                        </form>
                    <% } %>
                </div>
            </li>
        <% }) %>
    </ul>

    <div id="buyRequestModal" class="modal">
        <div class="modal-content">
            <button type="button" class="close" onclick="closeBuyRequestModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="section-heading" style="width:auto; margin-bottom:1rem;">
                <span class="eyebrow"><i class="fa-solid fa-paper-plane"></i> Offer</span>
                <h2>Send Buy Request</h2>
            </div>
            <form id="buyRequestForm" class="buy-request-form" action="/buy-request" method="POST">
                <input type="hidden" id="homeId" name="homeId">
                <div class="field">
                    <label for="offeredPrice">Your Offered Price</label>
                    <input type="number" id="offeredPrice" name="offeredPrice" required>
                </div>
                <div class="field">
                    <label for="message">Message to Owner</label>
                    <textarea id="message" name="message" rows="4" placeholder="Explain your interest and preferred timeline..." required></textarea>
                </div>
                <button type="submit">
                    <i class="fa-solid fa-paper-plane"></i>
                    <span>Send Request</span>
                </button>
            </form>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('propertySearch');
        const searchActionBtn = document.getElementById('searchActionBtn');
        const budgetPreference = document.getElementById('budgetPreference');
        const typePreference = document.getElementById('typePreference');
        const listingCards = Array.from(document.querySelectorAll('.listing-card'));
        const searchSummary = document.getElementById('searchSummary');
        const buyRequestModal = document.getElementById('buyRequestModal');
        const smartMatchStorageKey = 'homehive.smartMatchPreferences';

        const inferPropertyType = (text) => {
            const value = text.toLowerCase();
            if (value.includes('villa')) return 'villa';
            if (value.includes('apartment') || value.includes('flat')) return 'apartment';
            if (value.includes('studio')) return 'studio';
            if (value.includes('plot') || value.includes('land')) return 'plot';
            return 'house';
        };

        function savePreferences() {
            localStorage.setItem(smartMatchStorageKey, JSON.stringify({
                search: searchInput.value,
                budget: budgetPreference.value,
                type: typePreference.value,
            }));
        }

        function loadPreferences() {
            try {
                const saved = JSON.parse(localStorage.getItem(smartMatchStorageKey) || '{}');
                if (typeof saved.search === 'string') searchInput.value = saved.search;
                if (typeof saved.budget === 'string') budgetPreference.value = saved.budget;
                if (typeof saved.type === 'string') typePreference.value = saved.type;
            } catch (error) {
                localStorage.removeItem(smartMatchStorageKey);
            }
        }

        function getSmartMatchScore(card) {
            const query = searchInput.value.trim().toLowerCase();
            const budget = Number(budgetPreference.value || 0);
            const preferredType = typePreference.value;
            const cardText = card.dataset.search;
            const cardPrice = Number(card.dataset.price || 0);
            const cardType = inferPropertyType(cardText);
            let score = 55;

            if (query) {
                score += cardText.includes(query) ? 20 : 4;
            } else {
                score += 8;
            }

            if (budget > 0) {
                if (cardPrice <= budget) {
                    score += 17;
                } else if (cardPrice <= budget * 1.12) {
                    score += 10;
                } else {
                    score += 2;
                }
            } else {
                score += 10;
            }

            if (preferredType !== 'any') {
                score += cardType === preferredType ? 15 : 3;
            } else {
                score += 7;
            }

            return Math.max(52, Math.min(98, score));
        }

        function refreshSmartMatchScores() {
            listingCards.forEach((card) => {
                const score = getSmartMatchScore(card);
                const scoreNode = card.querySelector('[data-match-score]');
                if (scoreNode) {
                    scoreNode.textContent = `${score}% match`;
                }
            });
        }

        function filterListings() {
            const query = searchInput.value.trim().toLowerCase();
            const priceCap = Number(budgetPreference.value || 0);
            const preferredType = typePreference.value;
            let visibleCount = 0;

            listingCards.forEach((card) => {
                const matchesQuery = !query || card.dataset.search.includes(query);
                const matchesBudget = !priceCap || Number(card.dataset.price || 0) <= priceCap * 1.12;
                const matchesType = preferredType === 'any' || inferPropertyType(card.dataset.search) === preferredType;
                const matches = matchesQuery && matchesBudget && matchesType;
                card.style.display = matches ? '' : 'none';
                if (matches) {
                    visibleCount += 1;
                }
            });


            refreshSmartMatchScores();
            savePreferences();
        }

        function openBuyRequestModal(homeId, price) {
            document.getElementById('homeId').value = homeId;
            document.getElementById('offeredPrice').value = price;
            buyRequestModal.classList.add('show');
        }

        function closeBuyRequestModal() {
            buyRequestModal.classList.remove('show');
        }

        loadPreferences();
        searchInput.addEventListener('input', filterListings);
        budgetPreference.addEventListener('change', filterListings);
        typePreference.addEventListener('change', filterListings);
        searchActionBtn.addEventListener('click', filterListings);

        buyRequestModal.addEventListener('click', (event) => {
            if (event.target === buyRequestModal) {
                closeBuyRequestModal();
            }
        });

        filterListings();
    </script>
    <script src="/js/animations.js"></script>
</body>
</html>
