<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Saved Homes',
        pageDescription: 'Return to your shortlisted homes and continue comparing options.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'saved' }) %>

    <section class="page-section reveal">
        <div class="section-heading">
            <span class="eyebrow"><i class="fa-regular fa-heart"></i> Saved homes</span>
            <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Your shortlist</h1>
        </div>

        <% if (favourites && favourites.length > 0) { %>
            <div class="homes-list">
                <% favourites.forEach(home => { %>
                    <% const imageUrl = getHomeImageUrl(home.homeImage, { width: 720, height: 450 }); %>
                    <% const imageSrcSet = getHomeImageSrcSet(home.homeImage, [320, 480, 720], { height: 450 }); %>
                    <article class="home-card reveal">
                        <div class="home-media">
                            <img
                                src="<%= imageUrl %>"
                                <% if (imageSrcSet) { %>srcset="<%= imageSrcSet %>"<% } %>
                                sizes="(max-width: 840px) 100vw, (max-width: 1100px) 50vw, 33vw"
                                alt="Photo of <%= home.address?.formattedAddress || 'property' %>"
                                class="home-img"
                                loading="lazy"
                                decoding="async"
                                onerror="this.onerror=null;this.src='<%= imageFallbackUrl %>';"
                            />
                            <div class="card-badges">
                                <span class="verified-badge"><i class="fa-solid fa-heart"></i> Saved</span>
                            </div>
                        </div>
                        <div class="home-card-body">
                            <div class="price-highlight">
                                <div>
                                    <div class="price-label">Shortlist price</div>
                                    <strong>Rs <%= home.price %></strong>
                                </div>
                                <% if (home.propertyType) { %>
                                    <span class="meta-pill"><i class="fa-solid fa-house"></i><%= home.propertyType.charAt(0).toUpperCase() + home.propertyType.slice(1) %></span>
                                <% } %>
                            </div>
                            <h3><%= home.address?.formattedAddress || 'Property listing' %></h3>
                            <div class="home-meta">
                                <span class="meta-pill"><i class="fa-solid fa-location-dot"></i><%= home.address?.city || home.address?.state || 'Location pending' %></span>
                                <span class="meta-pill"><i class="fa-solid fa-star"></i>Favourite</span>
                            </div>
                            <p class="home-description"><%= home.description %></p>
                        </div>
                        <div class="card-actions">
                            <% if (isLoggedIn && user) { %>
                                <button type="button" class="btn btn-accent" onclick="openBuyRequestModal('<%= home.id %>', '<%= home.price %>')">
                                    <i class="fa-solid fa-paper-plane"></i>
                                    <span>Send offer</span>
                                </button>
                            <% } %>
                            <a class="Details" href="/home/<%= home.id %>">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                <span>View details</span>
                            </a>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state page-card">
                <span class="empty-state-icon"><i class="fa-regular fa-heart"></i></span>
                <span class="eyebrow">Nothing saved yet</span>
                <h3>Your shortlist is empty</h3>
                <p>Save properties from the listing grid to build a shortlist of homes worth revisiting.</p>
                <a href="/" class="btn btn-accent">
                    <i class="fa-solid fa-compass"></i>
                    <span>Explore listings</span>
                </a>
            </div>
        <% } %>
    </section>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <div class="footer-brand">
                    <i class="fa-solid fa-house"></i>
                    <strong>HomeHive</strong>
                </div>
                <p class="footer-desc">A simple platform for finding and listing properties.</p>
            </div>
            <div class="footer-col">
                <h4>Navigation</h4>
                <a href="/">Explore listings</a>
                <a href="/store/my-requests">My requests</a>
                <a href="/store/bookings">Meetings</a>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <a href="mailto:support@homehive.com">support@homehive.com</a>
                <p class="footer-contact-item"><i class="fa-solid fa-location-dot"></i> India</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 HomeHive. All rights reserved.</p>
        </div>
    </footer>

    <div id="buyRequestModal" class="modal">
        <div class="modal-content">
            <button type="button" class="close" onclick="closeBuyRequestModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="section-heading" style="margin-bottom:1.25rem;">
                <span class="eyebrow"><i class="fa-solid fa-paper-plane"></i> Make an offer</span>
                <h3>Send your offer</h3>
                <p>Submit your proposed price and a brief message to the owner.</p>
            </div>
            <form id="buyRequestForm" action="/buy-request" method="POST">
                <input type="hidden" id="homeId" name="homeId">
                <div class="field">
                    <label for="offeredPrice">Your offered price (Rs)</label>
                    <input type="number" id="offeredPrice" name="offeredPrice" required placeholder="Enter your offer amount">
                </div>
                <div class="field">
                    <label for="message">Message to owner</label>
                    <textarea id="message" name="message" rows="4" placeholder="Share your interest, timeline, or financing details..." required></textarea>
                </div>
                <button type="submit" class="btn btn-accent">
                    <i class="fa-solid fa-paper-plane"></i>
                    <span>Send offer</span>
                </button>
            </form>
        </div>
    </div>

    <script>
        const buyRequestModal = document.getElementById('buyRequestModal');

        function openBuyRequestModal(homeId, price) {
            document.getElementById('homeId').value = homeId;
            document.getElementById('offeredPrice').value = price;
            buyRequestModal.classList.add('show');
        }

        function closeBuyRequestModal() {
            buyRequestModal.classList.remove('show');
        }

        buyRequestModal.addEventListener('click', (event) => {
            if (event.target === buyRequestModal) closeBuyRequestModal();
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && buyRequestModal.classList.contains('show')) closeBuyRequestModal();
        });
    </script>

    <script src="/js/animations.js"></script>
</body>
</html>
