<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | My Requests',
        pageDescription: 'Track the status of your property offers and manage conversations with owners.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'my-requests' }) %>

    <section class="page-section reveal">
        <div class="section-heading">
            <span class="eyebrow"><i class="fa-solid fa-paper-plane"></i> My Requests</span>
            <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Your offers</h1>
        </div>

        <% if (buyRequests && buyRequests.length > 0) { %>
            <div class="card-list">
                <% buyRequests.forEach(request => { %>
                    <article class="request-card card-item" style="padding:1.35rem; display:grid; gap:1.25rem;">
                        <div class="stack">
                            <div class="price-highlight">
                                <div>
                                    <div class="price-label">Your offer</div>
                                    <strong>Rs <%= request.offeredPrice %></strong>
                                </div>
                                <span class="status <%= request.status %>"><%= request.status %></span>
                            </div>
                            <h3><%= request.home.address.formattedAddress %></h3>
                            <div class="home-meta">
                                <span class="meta-pill"><i class="fa-solid fa-user"></i><%= request.owner.firstname %> <%= request.owner.lastname %></span>
                                <span class="meta-pill"><i class="fa-solid fa-envelope"></i><%= request.owner.email %></span>
                                <span class="meta-pill"><i class="fa-solid fa-tag"></i>Rs <%= request.home.price %> (asking)</span>
                            </div>
                            <p style="font-size:0.88rem;line-height:1.65;"><%= request.message %></p>
                            <p class="helper-text">Sent on <%= request.createdAt.toDateString() %></p>
                        </div>
                        <div class="card-actions">
                            <button type="button" class="btn btn-secondary" onclick="openChat('<%= request._id %>', <%- JSON.stringify(`${request.owner.firstname} ${request.owner.lastname}`) %>)">
                                <i class="fa-solid fa-comments"></i>
                                <span>Open chat</span>
                            </button>
                            <a class="btn btn-secondary" href="/home/<%= request.home._id %>">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                <span>View property</span>
                            </a>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state page-card">
                <span class="empty-state-icon"><i class="fa-solid fa-paper-plane"></i></span>
                <span class="eyebrow">No offers yet</span>
                <h3>No offers sent</h3>
                <p>Browse properties and send an offer to get started.</p>
                <a href="/" class="btn btn-accent"><i class="fa-solid fa-compass"></i><span>Browse properties</span></a>
            </div>
        <% } %>
    </section>

    <div id="chatModal" class="modal">
        <div class="modal-content chat-modal">
            <button type="button" class="close" onclick="closeChatModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="chat-shell">
                <div class="chat-header">
                    <span class="chat-avatar"><i class="fa-solid fa-user"></i></span>
                    <div>
                        <h3 id="chatTitle">Conversation</h3>
                        <p class="chat-notice">Messages are not end-to-end encrypted.</p>
                    </div>
                </div>
                <div id="chatMessages" class="chat-messages"></div>
                <div class="chat-composer">
                    <input type="text" id="messageInput" placeholder="Type your message..." autocomplete="off">
                    <button type="button" onclick="sendMessage()" class="btn btn-accent">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/crypto.js"></script>
    <script>
        const socket = io();
        const currentUserId = <%- JSON.stringify(user.id) %>;
        const currentUserName = <%- JSON.stringify(`${user.firstname} ${user.lastname}`) %>;
        const chatModal = document.getElementById('chatModal');
        const chatMessages = document.getElementById('chatMessages');
        const chatTitle = document.getElementById('chatTitle');
        let currentRequestId = null;

        socket.emit('joinBuyerRoom', currentUserId);

        socket.on('requestStatusChanged', (data) => {
            if (window.showToast) {
                const statusText = data.status === 'accepted' ? 'accepted' : 'rejected';
                window.showToast(`Your offer was ${statusText} by ${data.ownerName}.`, data.status === 'accepted' ? 'success' : 'info');
            }
            setTimeout(() => location.reload(), 1500);
        });

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        async function renderMessages(messages) {
            chatMessages.innerHTML = '';
            if (!messages.length) {
                chatMessages.innerHTML = '<div class="chat-empty">No messages yet. Start the conversation.</div>';
                return;
            }

            for (const msg of messages) {
                const isMine = msg.sender && msg.sender._id === currentUserId;
                const row = document.createElement('div');
                row.className = `message-row ${isMine ? 'mine' : 'theirs'}`;
                const senderName = isMine ? currentUserName : `${msg.sender.firstname} ${msg.sender.lastname}`;
                const timeLabel = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                let decryptedMessage = msg.message;

                try {
                    const decoded = atob(msg.message);
                    if (decoded.startsWith('ENCRYPTED:')) {
                        const privateKey = CryptoUtils.getPrivateKey();
                        if (privateKey) {
                            decryptedMessage = await CryptoUtils.decryptMessage(msg.message, privateKey);
                        }
                    }
                } catch (error) {
                    // decryption failed — show raw
                }

                row.innerHTML = `
                    ${isMine ? '' : '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>'}
                    <div class="message-card">
                        <div class="message-meta">
                            <span>${escapeHtml(senderName)}</span>
                            <span>&middot;</span>
                            <span>${escapeHtml(timeLabel)}</span>
                        </div>
                        <div class="message-text">${escapeHtml(decryptedMessage)}</div>
                    </div>
                    ${isMine ? '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>' : ''}
                `;
                chatMessages.appendChild(row);
            }

            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        async function openChat(requestId, otherName) {
            currentRequestId = requestId;
            chatTitle.textContent = `Chat with ${otherName}`;
            chatModal.classList.add('show');
            await CryptoUtils.initCrypto();
            loadMessages(requestId);
            socket.emit('joinRoom', requestId);
        }

        function closeChatModal() {
            chatModal.classList.remove('show');
            currentRequestId = null;
            chatMessages.innerHTML = '';
        }

        function loadMessages(requestId) {
            fetch(`/messages/${requestId}`)
                .then(response => response.json())
                .then(messages => renderMessages(messages));
        }

        async function sendMessage() {
            const messageInput = document.getElementById('messageInput');
            const message = messageInput.value.trim();
            if (!message || !currentRequestId) return;

            try {
                const encryptedMessage = await CryptoUtils.encryptMessage(message, 'recipient-public-key-placeholder');
                socket.emit('sendMessage', {
                    requestId: currentRequestId,
                    message: encryptedMessage,
                    senderId: currentUserId
                });
                messageInput.value = '';
                if (window.showToast) window.showToast('Message sent.', 'success');
            } catch (error) {
                if (window.showToast) window.showToast('Failed to send the message.', 'error');
            }
        }

        socket.on('newMessage', (data) => {
            if (data.requestId === currentRequestId) loadMessages(currentRequestId);
        });

        document.getElementById('messageInput').addEventListener('keypress', function (event) {
            if (event.key === 'Enter') sendMessage();
        });

        chatModal.addEventListener('click', (event) => {
            if (event.target === chatModal) closeChatModal();
        });
    </script>
    <script src="/js/animations.js"></script>
</body>
</html>
