<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: `HomeHive | ${home.address?.city || 'Property'} Listing`,
        pageDescription: home.description || 'Explore full property details on HomeHive.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'explore' }) %>

    <section class="hero-section detail-shell">
        <div class="hero-card reveal home-details-container">
            <div class="detail-layout">
                <div class="detail-media">
                    <% const imageUrl = getHomeImageUrl(home.homeImage, { width: 1280, height: 760 }); %>
                    <% const imageSrcSet = getHomeImageSrcSet(home.homeImage, [640, 960, 1280, 1600], { height: 760 }); %>
                    <img
                        src="<%= imageUrl %>"
                        <% if (imageSrcSet) { %>srcset="<%= imageSrcSet %>"<% } %>
                        sizes="(max-width: 1100px) 100vw, 54vw"
                        alt="Photo of <%= home.address?.formattedAddress || 'property' %>"
                        loading="eager"
                        decoding="async"
                        onerror="this.onerror=null;this.src='<%= imageFallbackUrl %>';"
                    />
                </div>
                <div class="detail-content">
                    <span class="eyebrow"><i class="fa-solid fa-house-chimney-window"></i> Property details</span>
                    <h1 style="font-size:clamp(2rem,4vw,3.4rem);"><%= home.address?.formattedAddress || 'Property listing' %></h1>
                    <p><%= home.description %></p>

                    <div class="detail-highlights">
                        <div class="detail-highlight">
                            <span>Listing type</span>
                            <strong><%= home.propertyType ? `${home.propertyType.charAt(0).toUpperCase()}${home.propertyType.slice(1)}` : 'Residential' %></strong>
                        </div>
                        <div class="detail-highlight">
                            <span>Location focus</span>
                            <strong><%= home.address?.city || home.address?.state || 'Flexible location' %></strong>
                        </div>
                        <div class="detail-highlight">
                            <span>Budget band</span>
                            <strong>Rs <%= home.price %></strong>
                        </div>
                        <div class="detail-highlight">
                            <span>Experience</span>
                            <strong>Image-first preview</strong>
                        </div>
                    </div>

                    <div class="detail-panel">
                        <span class="eyebrow"><i class="fa-solid fa-circle-check"></i> Verified-ready listing</span>
                        <p style="margin:0.9rem 0 0;">This view keeps the most important information prominent: full address, pricing, listing type, and a larger property photo for quicker decision-making.</p>
                    </div>

                    <div class="card-actions" style="padding:0;">
                        <a href="/" class="btn btn-accent">
                            <i class="fa-solid fa-arrow-left"></i>
                            <span>Back to listings</span>
                        </a>
                        <% if (isLoggedIn && user && user.role === 'Buyer') { %>
                            <form action="/favourites/<%= home.id %>" method="POST" class="inline-form" data-toast-submit="Saved to your shortlist." data-toast-type="success">
                                <button type="submit" class="btn-secondary">
                                    <i class="fa-regular fa-heart"></i>
                                    <span>Save property</span>
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/animations.js"></script>
</body>
</html>
