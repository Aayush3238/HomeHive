<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeHive - Home Details</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="listing-bg listing-bg-left" aria-hidden="true"></div>
    <div class="listing-bg listing-bg-right" aria-hidden="true"></div>
    <div class="site-nav">
        <div class="navbar">
            <a class="nav-brand" href="/">
                <i class="fa-solid fa-house"></i>
                <span>HomeHive</span>
            </a>
            <div class="nav-links">
                <a href="/"><i class="fa-solid fa-compass"></i> Explore</a>
                <% if (isLoggedIn) { %>
                    <a href="/store/favourite-list"><i class="fa-regular fa-heart"></i> Saved</a>
                    <a href="/store/bookings"><i class="fa-regular fa-calendar-check"></i> Meetings</a>
                    <a href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
                <% } else { %>
                    <a href="/login"><i class="fa-solid fa-user"></i> Login</a>
                    <a href="/signup"><i class="fa-solid fa-user-plus"></i> Sign Up</a>
                <% } %>
            </div>
        </div>
    </div>

    <div class="home-details-container hero-card" style="background:var(--color-surface);border-color:rgba(28,24,22,0.06);">
        <div class="detail-layout">
            <div class="detail-media">
                <% const imageUrl = getHomeImageUrl(home.homeImage, { width: 1280, height: 760 }); %>
                <% const imageSrcSet = getHomeImageSrcSet(home.homeImage, [640, 960, 1280, 1600], { height: 760 }); %>
                <img
                    src="<%= imageUrl %>"
                    <% if (imageSrcSet) { %>srcset="<%= imageSrcSet %>"<% } %>
                    sizes="(max-width: 900px) 100vw, 58vw"
                    alt="Photo of <%= home.address?.formattedAddress || 'property' %>"
                    class="home-img"
                    loading="eager"
                    decoding="async"
                    onerror="this.onerror=null;this.src='<%= imageFallbackUrl %>';"
                />
            </div>
            <div class="detail-content">
                <span class="eyebrow"><i class="fa-solid fa-house-chimney"></i> Property details</span>
                <h1><%= home.address?.formattedAddress || '' %></h1>
                <div class="detail-meta">
                    <span class="meta-pill"><i class="fa-solid fa-wallet"></i>Rs <%= home.price %></span>
                    <span class="meta-pill"><i class="fa-solid fa-location-dot"></i><%= home.address?.city || home.address?.state || 'Location pending' %></span>
                </div>
                <div class="detail-description">
                    <h2>Overview</h2>
                    <p><%= home.description %></p>
                </div>
                <a href="/" class="btn btn-accent" style="justify-self:start;">
                    <i class="fa-solid fa-arrow-left"></i>
                    <span>Back to listings</span>
                </a>
            </div>
        </div>
    </div>
    <script src="/js/animations.js"></script>
</body>
</html>
