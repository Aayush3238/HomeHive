<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Sign Up',
        pageDescription: 'Create a HomeHive account to browse smarter, save homes, or manage listings as an owner.'
    }) %>
</head>
<body>
    <div class="auth-shell">
        <div class="page-card auth-card reveal" style="width:min(100%,680px);">
            <div class="section-heading" style="margin-bottom:0;">
                <span class="eyebrow"><i class="fa-solid fa-user-plus"></i> Create account</span>
                <h1 style="font-size:clamp(2rem,4vw,3.1rem);">Join HomeHive</h1>
                <p>Create an account to save properties, send offers, and manage listings.</p>
            </div>

            <% if (errorMessages && errorMessages.length > 0) { %>
                <div class="alert alert-error">
                    <% errorMessages.forEach(error => { %>
                        <p style="margin:0;"><%= error.msg %></p>
                    <% }) %>
                </div>
            <% } %>

            <form action="/signup" method="POST">
                <div class="field-grid">
                    <div class="field">
                        <label for="firstname">First name</label>
                        <input id="firstname" type="text" name="firstname" placeholder="First name" value="<%= oldInput?.firstname || '' %>" required>
                    </div>
                    <div class="field">
                        <label for="lastname">Last name</label>
                        <input id="lastname" type="text" name="lastname" placeholder="Last name" value="<%= oldInput?.lastname || '' %>" required>
                    </div>
                </div>
                <div class="field">
                    <label for="email">Email</label>
                    <input id="email" type="email" name="email" placeholder="Email" value="<%= oldInput?.email || '' %>" required>
                </div>
                <div class="field-grid">
                    <div class="field">
                        <label for="password">Password</label>
                        <input id="password" type="password" name="password" placeholder="Password" required>
                    </div>
                    <div class="field">
                        <label for="confirmPassword">Confirm password</label>
                        <input id="confirmPassword" type="password" name="confirmPassword" placeholder="Confirm password" required>
                    </div>
                </div>
                <div class="field">
                    <label>Choose your account type</label>
                    <div class="role-options">
                        <label class="btn btn-secondary" style="justify-content:flex-start;">
                            <input type="radio" name="role" value="Owner" <%= oldInput?.role === 'Owner' ? 'checked' : '' %> required>
                            <span><i class="fa-solid fa-house-user"></i> Owner</span>
                        </label>
                        <label class="btn btn-secondary" style="justify-content:flex-start;">
                            <input type="radio" name="role" value="Buyer" <%= oldInput?.role === 'Buyer' ? 'checked' : '' %> required>
                            <span><i class="fa-solid fa-key"></i> Buyer</span>
                        </label>
                    </div>
                </div>
                <button type="submit" class="btn btn-accent">
                    <i class="fa-solid fa-user-plus"></i>
                    <span>Create account</span>
                </button>
            </form>

            <div class="divider-text"><span>or</span></div>

            <a href="/auth/google" class="btn btn-google">
                <svg viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span>Continue with Google</span>
            </a>

            <p class="helper-text" style="text-align:center;margin:0;">Already have an account? <a href="/login" style="color:var(--accent);font-weight:700;">Login</a></p>
        </div>
    </div>
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <div class="footer-brand">
                    <i class="fa-solid fa-house"></i>
                    <strong>HomeHive</strong>
                </div>
                <p class="footer-desc">A simple platform for finding and listing properties.</p>
            </div>
            <div class="footer-col">
                <h4>Navigation</h4>
                <a href="/">Home</a>
                <a href="/login">Login</a>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <a href="mailto:support@homehive.com">support@homehive.com</a>
                <p class="footer-contact-item"><i class="fa-solid fa-location-dot"></i> India</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 HomeHive. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/animations.js"></script>
</body>
</html>
