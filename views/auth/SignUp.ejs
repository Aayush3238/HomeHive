<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeHive - Sign Up</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

    <div class="auth-shell">
        <div class="page-card auth-card auth-editorial" style="display:grid;gap:1.25rem;">
            <div>
                <span class="eyebrow"><i class="fa-solid fa-user-plus"></i> Create account</span>
                <h1 style="margin-top:0.25rem;">Join HomeHive</h1>
            </div>
            <% if (errorMessages && errorMessages.length > 0) { %>
                <div class="alert alert-error">
                    <% errorMessages.forEach(error => { %>
                        <p><%= error.msg %></p>
                    <% }) %>
                </div>
            <% } %>
            <form action="/signup" method="POST" class="stack">
                <div class="field-grid">
                    <div class="field">
                        <label for="firstname">First Name</label>
                        <input id="firstname" type="text" name="firstname" placeholder="First Name" value="<%= oldInput?.firstname || '' %>" required>
                    </div>
                    <div class="field">
                        <label for="lastname">Last Name</label>
                        <input id="lastname" type="text" name="lastname" placeholder="Last Name" value="<%= oldInput?.lastname || '' %>" required>
                    </div>
                </div>
                <div class="field">
                    <label for="email">Email</label>
                    <input id="email" type="email" name="email" placeholder="Email" value="<%= oldInput?.email || '' %>" required>
                </div>
                <div class="field-grid">
                    <div class="field">
                        <label for="password">Password</label>
                        <input id="password" type="password" name="password" placeholder="Password" required>
                    </div>
                    <div class="field">
                        <label for="confirmPassword">Confirm Password</label>
                        <input id="confirmPassword" type="password" name="confirmPassword" placeholder="Confirm Password" required>
                    </div>
                </div>
                <div class="role-group">
                    <p class="helper-text" style="margin-bottom:0.6rem;">Choose your account type</p>
                    <div class="role-options">
                        <label class="role-option">
                            <input type="radio" name="role" value="Owner" <%= oldInput?.role === 'Owner' ? 'checked' : '' %> required>
                            <span><i class="fa-solid fa-house-user"></i> Owner</span>
                        </label>
                        <label class="role-option">
                            <input type="radio" name="role" value="Buyer" <%= oldInput?.role === 'Buyer' ? 'checked' : '' %> required>
                            <span><i class="fa-solid fa-key"></i> Buyer</span>
                        </label>
                    </div>
                </div>
                <button type="submit">
                    <i class="fa-solid fa-user-plus"></i>
                    <span>Create Account</span>
                </button>
            </form>
            <p class="helper-text" style="text-align:center;margin-top:0.5rem;">
                Already have an account? <a href="/login" style="color:var(--color-sage-500);font-weight:700;text-decoration:none;">Login</a>
            </p>
        </div>
    </div>
    <script src="/js/animations.js"></script>
</body>
</html>
