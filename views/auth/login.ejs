<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Login',
        pageDescription: 'Sign in to manage saved homes, listings, requests, and meetings.'
    }) %>
</head>
<body>
    <div class="auth-shell">
        <div class="page-card auth-card reveal">
            <div class="section-heading" style="margin-bottom:0;">
                <span class="eyebrow"><i class="fa-solid fa-arrow-right-to-bracket"></i> Welcome back</span>
                <h1 style="font-size:clamp(2rem,4vw,3.1rem);">Login</h1>
                <p>Access your saved homes, conversations, and meetings.</p>
            </div>

            <% if (errorMessage) { %>
                <div class="alert alert-error"><%= errorMessage %></div>
            <% } %>

            <form action="/login" method="post">
                <div class="field">
                    <label for="email">Email</label>
                    <input id="email" type="email" name="email" placeholder="Email" value="<%= oldInput?.email || '' %>" required>
                </div>
                <div class="field">
                    <label for="password">Password</label>
                    <input id="password" type="password" name="password" placeholder="Password" required>
                </div>
                <button type="submit" class="btn btn-accent">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    <span>Login</span>
                </button>
            </form>

            <p class="helper-text" style="text-align:center;margin:0;">Don't have an account? <a href="/signup" style="color:var(--accent);font-weight:700;">Sign up</a></p>
        </div>
    </div>
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <div class="footer-brand">
                    <i class="fa-solid fa-house"></i>
                    <strong>HomeHive</strong>
                </div>
                <p class="footer-desc">A simple platform for finding and listing properties.</p>
            </div>
            <div class="footer-col">
                <h4>Navigation</h4>
                <a href="/">Home</a>
                <a href="/signup">Sign up</a>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <a href="mailto:support@homehive.com">support@homehive.com</a>
                <p class="footer-contact-item"><i class="fa-solid fa-location-dot"></i> India</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 HomeHive. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/animations.js"></script>
</body>
</html>
