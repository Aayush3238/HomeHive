<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Edit Listing',
        pageDescription: 'Update listing details while keeping the same premium browsing experience.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'dashboard' }) %>

    <section class="dashboard-page dashboard-page-spaced">
        <div class="dashboard-layout">
            <aside class="dashboard-sidebar reveal">
                <div class="dashboard-profile">
                    <div class="dashboard-avatar"><i class="fa-solid fa-pen"></i></div>
                    <div>
                        <span class="eyebrow"><i class="fa-solid fa-sliders"></i> Edit listing</span>
                        <h3>Update property details</h3>
                        <p>Keep your listing information up to date.</p>
                    </div>
                </div>
            </aside>

            <div class="dashboard-main reveal">
                <form action="/host/edit/<%= home._id %>" method="POST" enctype="multipart/form-data" class="listing-form">
                    <div class="section-heading">
                        <span class="eyebrow"><i class="fa-solid fa-pen-to-square"></i> Edit listing</span>
                        <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Refine your property</h1>
                    </div>

                    <div class="field-grid">
                        <div class="field">
                            <label for="houseNo">House number</label>
                            <input id="houseNo" type="text" name="houseNo" value="<%= home.address?.houseNo || '' %>" required>
                        </div>
                        <div class="field">
                            <label for="city">City</label>
                            <input id="city" type="text" name="city" value="<%= home.address?.city || '' %>" required>
                        </div>
                        <div class="field">
                            <label for="district">District</label>
                            <input id="district" type="text" name="district" value="<%= home.address?.district || '' %>">
                        </div>
                        <div class="field">
                            <label for="state">State</label>
                            <input id="state" type="text" name="state" value="<%= home.address?.state || '' %>" required>
                        </div>
                        <div class="field">
                            <label for="country">Country</label>
                            <input id="country" type="text" name="country" value="<%= home.address?.country || '' %>" required>
                        </div>
                        <div class="field">
                            <label for="postcode">Pincode / Postcode</label>
                            <input id="postcode" type="text" name="postcode" value="<%= home.address?.postcode || '' %>">
                        </div>
                        <div class="field">
                            <label for="price">Price</label>
                            <input id="price" type="number" name="price" value="<%= home.price %>" min="1" step="0.01" inputmode="decimal" required>
                        </div>
                        <div class="field">
                            <label for="propertyType">Property type</label>
                            <select id="propertyType" name="propertyType" required>
                                <option value="" <%= !home.propertyType ? 'selected' : '' %>>Select property type</option>
                                <option value="house" <%= home.propertyType === 'house' ? 'selected' : '' %>>House</option>
                                <option value="apartment" <%= home.propertyType === 'apartment' ? 'selected' : '' %>>Apartment</option>
                                <option value="villa" <%= home.propertyType === 'villa' ? 'selected' : '' %>>Villa</option>
                                <option value="studio" <%= home.propertyType === 'studio' ? 'selected' : '' %>>Studio</option>
                                <option value="plot" <%= home.propertyType === 'plot' ? 'selected' : '' %>>Plot</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label for="homeImage">Replace listing image</label>
                        <input id="homeImage" type="file" name="homeImage" accept="image/*">
                    </div>
                    <div class="field">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" required><%= home.description %></textarea>
                    </div>
                    <div class="action-row">
                        <button type="submit" class="btn btn-accent">
                            <i class="fa-solid fa-floppy-disk"></i>
                            <span>Save changes</span>
                        </button>
                        <a href="/host/host-homelist" class="btn btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i>
                            <span>Back</span>
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <script src="/js/animations.js"></script>
</body>
</html>
