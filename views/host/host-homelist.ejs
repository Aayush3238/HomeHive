<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Owner Dashboard',
        pageDescription: 'Manage listings, track activity, and respond to buyer demand from the HomeHive owner dashboard.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'dashboard' }) %>

    <section class="dashboard-page dashboard-page-spaced">
        <div class="dashboard-layout">
            <aside class="dashboard-sidebar reveal" data-sidebar>
                <div class="dashboard-profile">
                    <div class="dashboard-avatar"><i class="fa-solid fa-house-user"></i></div>
                    <div>
                        <span class="eyebrow"><i class="fa-solid fa-circle"></i> Owner workspace</span>
                        <h3><%= user?.firstname || 'Host' %> <%= user?.lastname || '' %></h3>
                    </div>
                </div>

                <button type="button" class="btn btn-secondary" data-sidebar-toggle>
                    <i class="fa-solid fa-bars-staggered"></i>
                    <span>Collapse sidebar</span>
                </button>

                <nav class="dashboard-menu">
                    <a class="btn btn-secondary" href="/host/host-homelist"><i class="fa-solid fa-chart-line"></i><span>Overview</span></a>
                    <a class="btn btn-secondary" href="/host/add-home"><i class="fa-solid fa-square-plus"></i><span>Add listing</span></a>
                    <a class="btn btn-secondary" href="/host/buy-requests"><i class="fa-solid fa-comments"></i><span>Buyer requests</span></a>
                    <a class="btn btn-secondary" href="/store/bookings"><i class="fa-regular fa-calendar-check"></i><span>Meetings</span></a>
                </nav>
            </aside>

            <main class="dashboard-main reveal">
                <div class="dashboard-header">
                    <div class="section-heading" style="margin-bottom:0;">
                        <span class="eyebrow"><i class="fa-solid fa-chart-pie"></i> Portfolio overview</span>
                        <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Your listings dashboard</h1>
                    </div>
                    <a href="/host/add-home" class="btn btn-accent">
                        <i class="fa-solid fa-square-plus"></i>
                        <span>Add new listing</span>
                    </a>
                </div>

                <section class="dashboard-metrics">
                    <article class="stat-card">
                        <span class="stat-label">Total listings</span>
                        <strong><%= SubmittedDetails.length %></strong>
                    </article>
                    <article class="stat-card">
                        <span class="stat-label">Map coverage</span>
                        <strong><%= SubmittedDetails.filter(home => home.location && home.location.coordinates && home.location.coordinates.length === 2).length %></strong>
                    </article>
                    <article class="stat-card">
                        <span class="stat-label">Property mix</span>
                        <strong><%= [...new Set(SubmittedDetails.map(home => home.propertyType).filter(Boolean))].length || 0 %></strong>
                    </article>
                    <article class="stat-card">
                        <span class="stat-label">Average price</span>
                        <strong>Rs <%= SubmittedDetails.length ? Math.round(SubmittedDetails.reduce((sum, home) => sum + (Number(home.price) || 0), 0) / SubmittedDetails.length).toLocaleString('en-IN') : 0 %></strong>
                    </article>
                </section>

                <section class="dashboard-panels">
                    <div class="page-card" style="padding:1.35rem;">
                        <div class="section-heading" style="margin-bottom:0.75rem;">
                            <span class="eyebrow"><i class="fa-solid fa-clock-rotate-left"></i> Recent activity</span>
                            <h3>What just changed</h3>
                        </div>
                        <div class="activity-list">
                            <% if (SubmittedDetails.length > 0) { %>
                                <% SubmittedDetails.slice(0, 3).forEach(home => { %>
                                    <article class="activity-item">
                                        <strong><%= home.address?.formattedAddress || 'Property listing' %></strong>
                                        <p>Published as <%= home.propertyType || 'residential' %> at Rs <%= Number(home.price || 0).toLocaleString('en-IN') %>.</p>
                                    </article>
                                <% }) %>
                            <% } else { %>
                                <article class="activity-item">
                                    <strong>No activity yet</strong>
                                    <p>Create your first listing to see activity here.</p>
                                </article>
                            <% } %>
                        </div>
                    </div>
                </section>

                <% if (SubmittedDetails && SubmittedDetails.length > 0) { %>
                    <section>
                        <div class="listings-toolbar">
                            <div class="section-heading" style="margin-bottom:0;">
                                <span class="eyebrow"><i class="fa-solid fa-building"></i> Inventory</span>
                                <h2 style="font-size:clamp(1.4rem,2.5vw,2rem);">Your live listings</h2>
                            </div>
                        </div>

                        <div class="homes-list">
                            <% SubmittedDetails.forEach(home => { %>
                                <% const imageUrl = getHomeImageUrl(home.homeImage, { width: 720, height: 450 }); %>
                                <article class="home-card reveal">
                                    <div class="home-media">
                                        <img
                                            src="<%= imageUrl %>"
                                            alt="Photo of <%= home.address?.formattedAddress || 'property' %>"
                                            class="home-img"
                                            loading="lazy"
                                            decoding="async"
                                            onerror="this.onerror=null;this.src='<%= imageFallbackUrl %>';"
                                        />
                                        <div class="card-badges">
                                            <span class="verified-badge"><i class="fa-solid fa-circle-check"></i> Live</span>
                                            <span class="match-badge"><i class="fa-solid fa-location-arrow"></i> Map aware</span>
                                        </div>
                                    </div>
                                    <div class="home-card-body">
                                        <div class="price-highlight">
                                            <div>
                                                <div class="price-label">Current price</div>
                                                <strong>Rs <%= home.price %></strong>
                                            </div>
                                            <span class="meta-pill"><i class="fa-solid fa-house"></i><%= home.propertyType || 'Home' %></span>
                                        </div>
                                        <h3><%= home.address?.formattedAddress || 'Property listing' %></h3>
                                        <div class="home-meta">
                                            <span class="meta-pill"><i class="fa-solid fa-location-dot"></i><%= home.address?.city || home.address?.state || 'Location pending' %></span>
                                            <span class="meta-pill"><i class="fa-solid fa-pen-ruler"></i>Editable</span>
                                        </div>
                                    </div>
                                    <div class="card-actions">
                                        <a href="/host/edit/<%= home.id %>" class="Details">
                                            <i class="fa-solid fa-pen"></i>
                                            <span>Edit listing</span>
                                        </a>
                                        <form action="/host/home-delete/<%= home.id %>" method="POST" class="inline-form" onsubmit="return confirm('Delete this listing permanently?');">
                                            <button type="submit" class="btn btn-danger">
                                                <i class="fa-solid fa-trash-can"></i>
                                                <span>Delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </article>
                            <% }) %>
                        </div>
                    </section>
                <% } else { %>
                    <div class="empty-state page-card">
                        <span class="empty-state-icon"><i class="fa-solid fa-house"></i></span>
                        <span class="eyebrow">No listings yet</span>
                        <h3>No listings yet</h3>
                        <p>Add your first property to get started.</p>
                        <a href="/host/add-home" class="btn btn-accent">
                            <i class="fa-solid fa-square-plus"></i>
                            <span>Add first listing</span>
                        </a>
                    </div>
                <% } %>
            </main>
        </div>
    </section>

    <script src="/js/animations.js"></script>
</body>
</html>
