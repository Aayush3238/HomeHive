<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Add Listing',
        pageDescription: 'Publish a new property with stronger validation, map support, and cleaner form UX.',
        extraHead: '<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'add-home' }) %>

    <section class="dashboard-page dashboard-page-spaced">
        <div class="dashboard-layout">
            <aside class="dashboard-sidebar reveal">
                <div class="dashboard-profile">
                    <div class="dashboard-avatar"><i class="fa-solid fa-square-plus"></i></div>
                    <div>
                        <span class="eyebrow"><i class="fa-solid fa-pen-nib"></i> New listing</span>
                        <h3>Add a property</h3>
                        <p>Fill in the details below to publish your listing.</p>
                    </div>
                </div>
                <div class="detail-panel">
                    <strong>Tips</strong>
                    <p>Add a clear address, property type, description, and at least one photo.</p>
                </div>
            </aside>

            <div class="dashboard-main reveal">
                <form action="/host/add-home" method="POST" enctype="multipart/form-data" class="listing-form">
                    <div class="section-heading">
                        <span class="eyebrow"><i class="fa-solid fa-building"></i> New property</span>
                        <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Add a new listing</h1>
                        <p>Fill in the property details below.</p>
                    </div>

                    <div class="field">
                        <label for="locationSearch">Search address</label>
                        <div class="autocomplete">
                            <input type="text" id="locationSearch" placeholder="Start typing a full address or landmark" autocomplete="off" required>
                            <div id="locationSuggestions" class="autocomplete-list" hidden></div>
                        </div>
                    </div>

                    <div class="map-card">
                        <div class="map-toolbar">
                            <span class="helper-text"><i class="fa-solid fa-circle-info"></i> Click the map or drag the marker to refine the address.</span>
                            <button type="button" id="useCurrentLocation" class="btn-secondary">
                                <i class="fa-solid fa-location-crosshairs"></i>
                                <span>Use current location</span>
                            </button>
                        </div>
                        <div class="map-wrapper">
                            <div id="map"></div>
                        </div>
                    </div>

                    <input type="hidden" name="lat" id="lat">
                    <input type="hidden" name="lng" id="lng">

                    <div class="coordinates-row">
                        <div class="field">
                            <label for="latPreview">Latitude</label>
                            <input id="latPreview" type="text" value="" readonly>
                        </div>
                        <div class="field">
                            <label for="lngPreview">Longitude</label>
                            <input id="lngPreview" type="text" value="" readonly>
                        </div>
                    </div>

                    <div class="field-grid">
                        <div class="field">
                            <label for="houseNo">House number</label>
                            <input id="houseNo" type="text" name="houseNo" placeholder="House number" required>
                        </div>
                        <div class="field">
                            <label for="city">City</label>
                            <input id="city" type="text" name="city" placeholder="City" required>
                        </div>
                        <div class="field">
                            <label for="district">District</label>
                            <input id="district" type="text" name="district" placeholder="District">
                        </div>
                        <div class="field">
                            <label for="state">State</label>
                            <input id="state" type="text" name="state" placeholder="State" required>
                        </div>
                        <div class="field">
                            <label for="country">Country</label>
                            <input id="country" type="text" name="country" placeholder="Country" required>
                        </div>
                        <div class="field">
                            <label for="postcode">Pincode / Postcode</label>
                            <input id="postcode" type="text" name="postcode" placeholder="Pincode">
                        </div>
                        <div class="field">
                            <label for="price">Price</label>
                            <input id="price" type="number" name="price" placeholder="Enter price" min="1" step="0.01" inputmode="decimal" required>
                        </div>
                        <div class="field">
                            <label for="propertyType">Property type</label>
                            <select id="propertyType" name="propertyType" required>
                                <option value="">Select property type</option>
                                <option value="house">House</option>
                                <option value="apartment">Apartment</option>
                                <option value="villa">Villa</option>
                                <option value="studio">Studio</option>
                                <option value="plot">Plot</option>
                            </select>
                        </div>
                    </div>

                    <div class="field-grid">
                        <div class="field">
                            <label for="homeImage">Home image</label>
                            <input type="file" id="homeImage" name="homeImage" accept="image/*">
                        </div>
                        <div class="field">
                            <label for="description">Description</label>
                            <textarea id="description" name="description" placeholder="Describe what makes this listing special" required></textarea>
                        </div>
                    </div>

                    <div class="action-row">
                        <button type="submit" class="btn btn-accent">
                            <i class="fa-solid fa-square-plus"></i>
                            <span>Add home</span>
                        </button>
                        <a href="/host/host-homelist" class="btn btn-secondary">
                            <i class="fa-solid fa-arrow-left"></i>
                            <span>Back to dashboard</span>
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="/js/map-sync.js"></script>
    <script>
        initAddressMapSync({
            mapId: 'map',
            addressInputId: 'locationSearch',
            suggestionListId: 'locationSuggestions',
            latInputId: 'lat',
            lngInputId: 'lng',
            useCurrentLocationButtonId: 'useCurrentLocation',
            initialAddress: '',
        });

        const latInput = document.getElementById('lat');
        const lngInput = document.getElementById('lng');
        const latPreview = document.getElementById('latPreview');
        const lngPreview = document.getElementById('lngPreview');

        const syncPreview = () => {
            latPreview.value = latInput.value;
            lngPreview.value = lngInput.value;
        };

        latInput.addEventListener('input', syncPreview);
        lngInput.addEventListener('input', syncPreview);
        syncPreview();
    </script>
    <script src="/js/animations.js"></script>
</body>
</html>
