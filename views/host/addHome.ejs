<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeHive - Add Home</title>
    <link rel="stylesheet" href="/app.css">
    <link rel="stylesheet" href="/AddHome.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="form-bg form-bg-left" aria-hidden="true"></div>
    <div class="form-bg form-bg-right" aria-hidden="true"></div>
    <div class="site-nav">
        <div class="navbar">
            <a class="nav-brand" href="/">
                <i class="fa-solid fa-house"></i>
                <span>HomeHive</span>
            </a>
            <div class="nav-links">
                <a href="/"><i class="fa-solid fa-compass"></i> Explore</a>
                <a class="is-active" href="/host/add-home"><i class="fa-solid fa-square-plus"></i> Add Listing</a>
                <a href="/host/host-homelist"><i class="fa-solid fa-table-cells-large"></i> Dashboard</a>
                <a href="/host/buy-requests"><i class="fa-solid fa-comments"></i> Requests</a>
                <a href="/store/bookings"><i class="fa-regular fa-calendar-check"></i> Meetings</a>
                <a href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
            </div>
        </div>
    </div>

    <section class="form-page">
        <div class="form-layout">
            <form action="/host/add-home" method="POST" enctype="multipart/form-data" class="listing-form">
                <div class="form-header">
                    <h1>Add a new listing</h1>
                </div>
                <div class="field">
                    <label for="locationSearch">Search address</label>
                    <div class="autocomplete">
                        <input type="text" id="locationSearch" placeholder="Start typing a full address or landmark" autocomplete="off" required>
                        <div id="locationSuggestions" class="autocomplete-list" hidden></div>
                    </div>
                </div>

                <div class="map-card">
                    <div class="map-toolbar">
                        <span class="map-helper"><i class="fa-solid fa-circle-info"></i> Click the map or drag the marker to refine the address.</span>
                        <button type="button" id="useCurrentLocation" class="btn btn-secondary">
                            <i class="fa-solid fa-location-crosshairs"></i>
                            <span>Use My Current Location</span>
                        </button>
                    </div>
                    <div class="map-wrapper">
                        <div id="map"></div>
                    </div>
                </div>

                <input type="hidden" name="lat" id="lat">
                <input type="hidden" name="lng" id="lng">

                <div class="coordinates-row">
                    <div class="field">
                        <label for="latPreview">Latitude</label>
                        <input id="latPreview" type="text" value="" readonly>
                    </div>
                    <div class="field">
                        <label for="lngPreview">Longitude</label>
                        <input id="lngPreview" type="text" value="" readonly>
                    </div>
                </div>

                <div class="field-grid">
                    <div class="field">
                        <label for="houseNo">House Number</label>
                        <input id="houseNo" type="text" name="houseNo" placeholder="House number" required>
                    </div>
                    <div class="field">
                        <label for="city">City</label>
                        <input id="city" type="text" name="city" placeholder="City" required>
                    </div>
                    <div class="field">
                        <label for="district">District</label>
                        <input id="district" type="text" name="district" placeholder="District">
                    </div>
                    <div class="field">
                        <label for="state">State</label>
                        <input id="state" type="text" name="state" placeholder="State" required>
                    </div>
                    <div class="field">
                        <label for="country">Country</label>
                        <input id="country" type="text" name="country" placeholder="Country" required>
                    </div>
                    <div class="field">
                        <label for="price">Price</label>
                        <input id="price" type="text" name="price" placeholder="Enter price" required>
                    </div>
                </div>

                <div class="field-grid">
                    <div class="field">
                        <label for="homeImage">Home Image</label>
                        <input type="file" id="homeImage" name="homeImage" accept="image/*">
                    </div>
                    <div class="field">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" placeholder="Describe what makes this listing special" required></textarea>
                    </div>
                </div>

                <div class="action-row">
                    <button type="submit">
                        <i class="fa-solid fa-square-plus"></i>
                        <span>Add Home</span>
                    </button>
                    <a href="/host/host-homelist" class="btn btn-secondary">
                        <i class="fa-solid fa-arrow-left"></i>
                        <span>Back to Listings</span>
                    </a>
                </div>
            </form>
        </div>
    </section>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="/js/map-sync.js"></script>
    <script>
        initAddressMapSync({
            mapId: 'map',
            addressInputId: 'locationSearch',
            suggestionListId: 'locationSuggestions',
            latInputId: 'lat',
            lngInputId: 'lng',
            useCurrentLocationButtonId: 'useCurrentLocation',
            initialAddress: '',
        });

        const latInput = document.getElementById('lat');
        const lngInput = document.getElementById('lng');
        const latPreview = document.getElementById('latPreview');
        const lngPreview = document.getElementById('lngPreview');

        const syncPreview = () => {
            latPreview.value = latInput.value;
            lngPreview.value = lngInput.value;
        };

        latInput.addEventListener('input', syncPreview);
        lngInput.addEventListener('input', syncPreview);
        syncPreview();
    </script>
</body>
</html>
