<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Buyer Requests',
        pageDescription: 'Review incoming offers, continue conversations, and schedule meetings with buyers.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'requests' }) %>

    <section class="dashboard-page dashboard-page-spaced">
        <div class="dashboard-layout">
            <aside class="dashboard-sidebar reveal" data-sidebar>
                <div class="dashboard-profile">
                    <div class="dashboard-avatar"><i class="fa-solid fa-comments-dollar"></i></div>
                    <div>
                        <span class="eyebrow"><i class="fa-solid fa-wave-square"></i> Demand pipeline</span>
                        <h3 style="margin-top:0.75rem;">Buyer requests</h3>
                        <p style="margin:0.35rem 0 0;">Review inbound offers, reply quickly, and move accepted buyers into meetings.</p>
                    </div>
                </div>
                <nav class="dashboard-menu">
                    <a class="btn btn-secondary" href="/host/host-homelist"><i class="fa-solid fa-chart-line"></i><span>Overview</span></a>
                    <a class="btn btn-secondary" href="/host/add-home"><i class="fa-solid fa-square-plus"></i><span>Add listing</span></a>
                    <a class="btn btn-secondary" href="/store/bookings"><i class="fa-regular fa-calendar-check"></i><span>Meetings</span></a>
                </nav>
            </aside>

            <main class="dashboard-main reveal">
                <div class="section-heading" style="margin-bottom:0;">
                    <span class="eyebrow"><i class="fa-solid fa-comments"></i> Incoming demand</span>
                    <h1 style="font-size:clamp(2rem,4vw,3.4rem);">Requests for your properties</h1>
                    <p>Approve, reject, or move buyers forward to scheduling without losing chat context.</p>
                </div>

                <% if (buyRequests.length === 0) { %>
                    <div class="empty-state page-card">
                        <span class="empty-state-icon"><i class="fa-solid fa-inbox"></i></span>
                        <span class="eyebrow">No requests yet</span>
                        <h3>Nothing has landed in the pipeline yet.</h3>
                        <p>Once buyers start submitting offers, this page becomes your control center for replies, chat, and scheduling.</p>
                    </div>
                <% } else { %>
                    <div class="card-list">
                        <% buyRequests.forEach(request => { %>
                            <article class="request-card card-item" style="padding:1.25rem; display:grid; gap:1rem;">
                                <div class="stack">
                                    <div class="price-highlight">
                                        <div>
                                            <div class="price-label">Offered price</div>
                                            <strong>Rs <%= request.offeredPrice %></strong>
                                        </div>
                                        <span class="status <%= request.status %>"><%= request.status %></span>
                                    </div>
                                    <h3><%= request.home.address.formattedAddress %></h3>
                                    <div class="home-meta">
                                        <span class="meta-pill"><i class="fa-solid fa-user"></i><%= request.buyer.firstname %> <%= request.buyer.lastname %></span>
                                        <span class="meta-pill"><i class="fa-solid fa-envelope"></i><%= request.buyer.email %></span>
                                    </div>
                                    <p><%= request.message %></p>
                                    <p class="helper-text">Requested on <%= request.createdAt.toDateString() %></p>
                                </div>
                                <div class="card-actions">
                                    <% if (request.status === 'pending') { %>
                                        <form action="/host/buy-request/<%= request._id %>/accept" method="POST" class="inline-form">
                                            <button type="submit" class="btn btn-accent">
                                                <i class="fa-solid fa-check"></i>
                                                <span>Accept</span>
                                            </button>
                                        </form>
                                        <form action="/host/buy-request/<%= request._id %>/reject" method="POST" class="inline-form">
                                            <button type="submit" class="btn-danger">
                                                <i class="fa-solid fa-xmark"></i>
                                                <span>Reject</span>
                                            </button>
                                        </form>
                                    <% } %>
                                    <button type="button" class="btn btn-secondary" onclick="openChat('<%= request._id %>', <%- JSON.stringify(`${request.buyer.firstname} ${request.buyer.lastname}`) %>)">
                                        <i class="fa-solid fa-comments"></i>
                                        <span>Open chat</span>
                                    </button>
                                    <% if (request.status === 'accepted') { %>
                                        <button type="button" class="btn btn-accent" onclick="scheduleMeeting('<%= request._id %>')">
                                            <i class="fa-regular fa-calendar-check"></i>
                                            <span>Schedule meeting</span>
                                        </button>
                                    <% } %>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                <% } %>
            </main>
        </div>
    </section>

    <div id="chatModal" class="modal">
        <div class="modal-content chat-modal">
            <button type="button" class="close" onclick="closeChatModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="chat-shell">
                <div class="chat-header">
                    <span class="chat-avatar"><i class="fa-solid fa-user"></i></span>
                    <div>
                        <h3 id="chatTitle">Conversation</h3>
                        <p class="chat-notice">Messages are not end-to-end encrypted.</p>
                    </div>
                </div>
                <div id="chatMessages" class="chat-messages"></div>
                <div class="chat-composer">
                    <input type="text" id="messageInput" placeholder="Type your message..." autocomplete="off">
                    <button type="button" onclick="sendMessage()" class="btn btn-accent">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="meetingModal" class="modal">
        <div class="modal-content">
            <button type="button" class="close" onclick="closeMeetingModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="section-heading" style="margin-bottom:1rem;">
                <span class="eyebrow"><i class="fa-regular fa-calendar-check"></i> Meeting setup</span>
                <h3>Schedule meeting</h3>
            </div>
            <form id="meetingForm" action="/schedule-meeting" method="POST">
                <input type="hidden" id="meetingRequestId" name="requestId">
                <div class="field">
                    <label for="meetingDate">Date and time</label>
                    <input type="datetime-local" id="meetingDate" name="scheduledDate" required>
                </div>
                <div class="field">
                    <label for="meetingLocation">Location</label>
                    <input type="text" id="meetingLocation" name="location" placeholder="Meeting location" required>
                </div>
                <div class="field">
                    <label for="meetingNotes">Notes</label>
                    <textarea id="meetingNotes" name="notes" rows="3" placeholder="Additional notes..."></textarea>
                </div>
                <button type="submit" class="btn btn-accent">
                    <i class="fa-regular fa-calendar-check"></i>
                    <span>Schedule meeting</span>
                </button>
            </form>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/crypto.js"></script>
    <script>
        const socket = io();
        const currentUserId = <%- JSON.stringify(user.id) %>;
        const currentUserName = <%- JSON.stringify(`${user.firstname} ${user.lastname}`) %>;
        const chatModal = document.getElementById('chatModal');
        const meetingModal = document.getElementById('meetingModal');
        const chatMessages = document.getElementById('chatMessages');
        const chatTitle = document.getElementById('chatTitle');
        let currentRequestId = null;

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        async function renderMessages(messages) {
            chatMessages.innerHTML = '';
            if (!messages.length) {
                chatMessages.innerHTML = '<div class="chat-empty">No messages yet. Start the conversation.</div>';
                return;
            }

            for (const msg of messages) {
                const isMine = msg.sender && msg.sender._id === currentUserId;
                const row = document.createElement('div');
                row.className = `message-row ${isMine ? 'mine' : 'theirs'}`;
                const senderName = isMine ? currentUserName : `${msg.sender.firstname} ${msg.sender.lastname}`;
                const timeLabel = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                let decryptedMessage = msg.message;

                try {
                    const decoded = atob(msg.message);
                    if (decoded.startsWith('ENCRYPTED:')) {
                        const privateKey = CryptoUtils.getPrivateKey();
                        if (privateKey) decryptedMessage = await CryptoUtils.decryptMessage(msg.message, privateKey);
                    }
                } catch (error) {
                    console.warn('Could not decrypt message:', error);
                }

                row.innerHTML = `
                    ${isMine ? '' : '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>'}
                    <div class="message-card">
                        <div class="message-meta">
                            <span>${escapeHtml(senderName)}</span>
                            <span>•</span>
                            <span>${escapeHtml(timeLabel)}</span>
                        </div>
                        <div class="message-text">${escapeHtml(decryptedMessage)}</div>
                    </div>
                    ${isMine ? '<span class="chat-avatar"><i class="fa-solid fa-user"></i></span>' : ''}
                `;
                chatMessages.appendChild(row);
            }

            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        async function openChat(requestId, buyerName) {
            currentRequestId = requestId;
            chatTitle.textContent = `Chat with ${buyerName}`;
            chatModal.classList.add('show');
            await CryptoUtils.initCrypto();
            loadMessages(requestId);
            socket.emit('joinRoom', requestId);
        }

        function closeChatModal() {
            chatModal.classList.remove('show');
            currentRequestId = null;
            chatMessages.innerHTML = '';
        }

        function scheduleMeeting(requestId) {
            document.getElementById('meetingRequestId').value = requestId;
            meetingModal.classList.add('show');
        }

        function closeMeetingModal() {
            meetingModal.classList.remove('show');
        }

        function loadMessages(requestId) {
            fetch(`/messages/${requestId}`)
                .then(response => response.json())
                .then(messages => renderMessages(messages));
        }

        async function sendMessage() {
            const messageInput = document.getElementById('messageInput');
            const message = messageInput.value.trim();
            if (!message || !currentRequestId) return;

            try {
                const encryptedMessage = await CryptoUtils.encryptMessage(message, 'recipient-public-key-placeholder');
                socket.emit('sendMessage', {
                    requestId: currentRequestId,
                    message: encryptedMessage,
                    senderId: currentUserId
                });
                messageInput.value = '';
                if (window.showToast) window.showToast('Message sent.', 'success');
            } catch (error) {
                console.error('Error encrypting message:', error);
                if (window.showToast) window.showToast('Failed to send the message.', 'error');
            }
        }

        socket.on('newMessage', (data) => {
            if (data.requestId === currentRequestId) loadMessages(currentRequestId);
        });

        document.getElementById('messageInput').addEventListener('keypress', function (event) {
            if (event.key === 'Enter') sendMessage();
        });

        chatModal.addEventListener('click', (event) => {
            if (event.target === chatModal) closeChatModal();
        });

        meetingModal.addEventListener('click', (event) => {
            if (event.target === meetingModal) closeMeetingModal();
        });
    </script>
    <script src="/js/animations.js"></script>
</body>
</html>
