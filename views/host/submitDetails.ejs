<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Listing Published',
        pageDescription: 'Your new property listing is now live on HomeHive.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'dashboard' }) %>

    <section class="auth-shell">
        <div class="page-card auth-card" style="text-align:center;">
            <div style="display:flex;flex-direction:column;align-items:center;gap:0.75rem;">
                <span class="eyebrow"><i class="fa-solid fa-circle-check"></i> Listing published</span>
                <h1 style="font-size:clamp(1.75rem,3.5vw,2.75rem);">Your property is live.</h1>
                <p>The listing has been added and is now ready for buyers to discover, save, and request.</p>
                <div style="display:flex;gap:0.65rem;flex-wrap:wrap;justify-content:center;">
                    <a href="/host/host-homelist" class="btn btn-accent">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Open dashboard</span>
                    </a>
                    <a href="/" class="btn btn-secondary">
                        <i class="fa-solid fa-compass"></i>
                        <span>View explorer</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/animations.js"></script>
</body>
</html>
