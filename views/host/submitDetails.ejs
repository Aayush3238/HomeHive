<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeHive - Home Added</title>
    <link rel="stylesheet" href="/app.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="listing-bg listing-bg-left" aria-hidden="true"></div>
    <div class="listing-bg listing-bg-right" aria-hidden="true"></div>
    <div class="site-nav">
        <div class="navbar">
            <a class="nav-brand" href="/">
                <i class="fa-solid fa-house"></i>
                <span>HomeHive</span>
            </a>
            <div class="nav-links">
                <a href="/"><i class="fa-solid fa-compass"></i> Explore</a>
                <% if (isLoggedIn) { %>
                    <% if (user.role === 'Owner') { %>
                        <a href="/host/add-home"><i class="fa-solid fa-square-plus"></i> Add Listing</a>
                        <a href="/host/host-homelist"><i class="fa-solid fa-table-cells-large"></i> Dashboard</a>
                        <a href="/host/buy-requests"><i class="fa-solid fa-comments"></i> Requests</a>
                    <% } %>
                    <a href="/store/bookings"><i class="fa-regular fa-calendar-check"></i> Meetings</a>
                    <a href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
                <% } else { %>
                    <a href="/login"><i class="fa-solid fa-user"></i> Login</a>
                    <a href="/signup"><i class="fa-solid fa-user-plus"></i> Sign Up</a>
                <% } %>
            </div>
        </div>
    </div>

    <section class="hero-section">
        <div class="hero-card">
            <div class="hero-copy">
                <h1>Home Added Successfully!</h1>
                <p>Your listing has been submitted and is now live on HomeHive.</p>
                <div class="hero-search-shell">
                    <a href="/" class="btn btn-accent">
                        <i class="fa-solid fa-compass"></i>
                        <span>Explore Listings</span>
                    </a>
                    <a href="/host/host-homelist" class="btn btn-secondary">
                        <i class="fa-solid fa-table-cells-large"></i>
                        <span>View My Listings</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
</body>
</html>