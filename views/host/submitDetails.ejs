<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomeHive - Home Added</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
    <div class="listing-bg listing-bg-left" aria-hidden="true"></div>
    <div class="listing-bg listing-bg-right" aria-hidden="true"></div>
    <div class="site-nav">
        <div class="navbar">
            <a class="nav-brand" href="/">
                <i class="fa-solid fa-house"></i>
                <span>HomeHive</span>
            </a>
            <div class="nav-links">
                <a href="/"><i class="fa-solid fa-compass"></i> Explore</a>
                <% if (isLoggedIn) { %>
                    <% if (user.role === 'Owner') { %>
                        <a href="/host/add-home"><i class="fa-solid fa-square-plus"></i> Add Listing</a>
                        <a href="/host/host-homelist"><i class="fa-solid fa-table-cells-large"></i> Dashboard</a>
                        <a href="/host/buy-requests"><i class="fa-solid fa-comments"></i> Requests</a>
                    <% } %>
                    <a href="/store/bookings"><i class="fa-regular fa-calendar-check"></i> Meetings</a>
                    <a href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
                <% } else { %>
                    <a href="/login"><i class="fa-solid fa-user"></i> Login</a>
                    <a href="/signup"><i class="fa-solid fa-user-plus"></i> Sign Up</a>
                <% } %>
            </div>
        </div>
    </div>

    <section class="hero-section">
        <div class="hero-blob hero-blob--1" aria-hidden="true"></div>
        <div class="hero-blob hero-blob--2" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-mote" aria-hidden="true"></div>
        <div class="hero-card">
            <div class="hero-copy" style="text-align:center;">
                <h1>Home Added Successfully!</h1>
                <p>Your listing has been submitted and is now live on HomeHive.</p>
                <div class="hero-search-shell" style="width:auto;align-items:center;">
                    <a href="/" class="btn btn-accent" style="justify-self:center;">
                        <i class="fa-solid fa-compass"></i>
                        <span>Explore Listings</span>
                    </a>
                    <a href="/host/host-homelist" class="btn-secondary" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.85rem 1.2rem;border-radius:999px;font-weight:700;font-size:0.92rem;cursor:pointer;border:1px solid rgba(28,24,22,0.10);background:rgba(255,252,249,0.95);color:#1c1816;justify-self:center;text-decoration:none;transition:all 0.25s ease;">
                        <i class="fa-solid fa-table-cells-large"></i>
                        <span>View My Listings</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
    <script src="/js/animations.js"></script>
</body>
</html>
