<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'HomeHive | Listing Published',
        pageDescription: 'Your new property listing is now live on HomeHive.'
    }) %>
</head>
<body>
    <%- include('../partials/nav', { activeNav: 'dashboard' }) %>

    <section class="hero-section">
        <div class="hero-card reveal" style="text-align:center;">
            <div class="hero-copy" style="justify-items:center;">
                <span class="eyebrow"><i class="fa-solid fa-circle-check"></i> Listing published</span>
                <h1 style="font-size:clamp(2.4rem,7vw,4.6rem);">Your property is live.</h1>
                <p>The listing has been added to the premium browse flow and is now ready for buyers to discover, save, and request.</p>
                <div class="hero-cta-row" style="justify-content:center;">
                    <a href="/host/host-homelist" class="btn btn-accent">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Open dashboard</span>
                    </a>
                    <a href="/" class="btn btn-secondary">
                        <i class="fa-solid fa-compass"></i>
                        <span>View explorer</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script src="/js/animations.js"></script>
</body>
</html>
